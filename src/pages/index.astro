      gap: 1.5rem;
      /* let the panel grow with its content so the border-top extends to
         the right edge of the logo strip, instead of stopping at the
         narrower hero-inner max-width */
      width: max-content;
      max-width: 100%;
    }
  }
  .hero-trust-panel-label {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-coral);
    flex: none;
  }
  /* Single horizontal row of logos at desktop. At tablet widths we shrink
     gap + logo heights so all five still fit in one row instead of wrapping
     to two visually-unbalanced rows. */
  .hero-trust-panel-logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.875rem 1.25rem;
  }
  @media (min-width: 640px) and (max-width: 899px) {
    .hero-trust-panel-logos {
      flex-wrap: nowrap;
      gap: 0.875rem;
    }
    .hero-trust-logo-chcf { height: 22px; }
    .hero-trust-logo-stat { height: 18px; }
    .hero-trust-logo-modbee { font-size: 0.78rem; letter-spacing: 0.02em; }
    .hero-trust-logo-steinberg { height: 22px; }
    .hero-trust-logo-healthline { height: 16px; }
  }
  @media (min-width: 900px) {
    .hero-trust-panel-logos {
      flex-wrap: nowrap;
      gap: 1.5rem;
    }
  }
  .hero-trust-link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
    flex: none;
    border-radius: 4px;
  }
  .hero-trust-link:focus-visible {
    outline: 2px solid var(--color-coral);
    outline-offset: 4px;
  }
  .hero-trust-logo {
    display: inline-flex;
    align-items: center;
    flex: none;
    width: auto;
    /* Logos render in their original brand colors. */
    opacity: 0.85;
    transition: opacity 200ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .hero-trust-link:hover .hero-trust-logo,
  .hero-trust-logo:hover {
    opacity: 1;
  }
  .hero-trust-logo-chcf { height: 28px; }
  .hero-trust-logo-stat { height: 22px; }
  .hero-trust-logo-modbee {
    font-family: Georgia, "Times New Roman", serif;
    font-weight: 700;
    font-style: italic;
    font-size: 1.125rem;
    line-height: 1;
    color: #ffffff;
    letter-spacing: -0.01em;
    user-select: none;
  }
  .hero-trust-logo-steinberg { height: 28px; }
  .hero-trust-logo-healthline { height: 20px; }
  @media (min-width: 900px) {
    .hero-trust-logo-chcf { height: 34px; }
    .hero-trust-logo-stat { height: 26px; }
    .hero-trust-logo-modbee { font-size: 1.25rem; }
    .hero-trust-logo-steinberg { height: 32px; }
    .hero-trust-logo-healthline { height: 24px; }
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    margin: 0 0 1rem 0;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-on-navy-soft);
    letter-spacing: 0.01em;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-weight: 400;
    color: var(--color-on-navy);
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0 0 1.25rem 0;
    max-width: 18ch;
    text-wrap: balance;
  }

  .hero-subhead {
    font-family: var(--font-sans);
    font-weight: 400;
    color: var(--color-on-navy-soft);
    font-size: clamp(1rem, 1.3vw, 1.125rem);
    line-height: 1.55;
    margin: 0 0 1.5rem 0;
    max-width: 44ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.25rem;
    margin-bottom: 0.875rem;
  }
  .hero-enroll-link {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-on-navy-soft);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .hero-enroll-link:hover {
    color: var(--color-coral);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .hero-cta-note {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-on-navy-soft);
  }
  .hero-cta-note em {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-on-navy-soft);
  }

  .hero-trust {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-on-navy-quiet);
    max-width: 44ch;
    margin: 0;
    border-top: 1px solid oklch(0.97 0.012 70 / 0.18);
    padding-top: 1rem;
  }

  /* ----- FRAMING ----- */
  .framing {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background-color: var(--color-paper);
    background-image: url('/images/topo-dark.svg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    border-top: 1px solid var(--color-rule);
  }
  @media (min-width: 768px) {
    .framing {
      padding-top: 7rem;
      padding-bottom: 7rem;
    }
  }
  .framing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 900px) {
    .framing-grid {
      grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
      gap: 4rem;
    }
  }
  .framing-prose {
    max-width: 36ch;
  }
  .framing-text {
    font-family: var(--font-serif);
    font-weight: 400;
    color: var(--color-navy);
    font-size: clamp(1.3rem, 2vw, 1.625rem);
    line-height: 1.45;
    letter-spacing: -0.005em;
    margin: 0;
    text-wrap: pretty;
    text-align: left;
  }
  .framing-aside {
    margin: 1.5rem 0 0 0;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-rule);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.25rem, 2.2vw, 1.625rem);
    line-height: 1.4;
    color: var(--color-navy);
  }
  .framing-photo {
    margin: 0;
  }
  .framing-photo-img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 16px;
    box-shadow:
      0 2px 4px oklch(0 0 0 / 0.06),
      0 16px 40px oklch(0 0 0 / 0.12);
  }
  .framing-photo-caption {
    margin-top: 0.75rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.875rem;
    color: var(--color-ink-quiet);
    text-align: right;
    line-height: 1.4;
  }

  /* ----- PROGRAM (table of contents) ----- */
  .program {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background-color: var(--color-paper-soft);
  }
  @media (min-width: 768px) {
    .program {
      padding-top: 7rem;
      padding-bottom: 7rem;
    }
  }

  .program-grid {
    list-style: none;
    margin: 3rem 0 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 720px) {
    .program-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
  }
  /* Module 7 (closing module) spans the full row at 720px+ */
  @media (min-width: 720px) {
    .program-card:last-child {
      grid-column: 1 / -1;
    }
  }
  .program-card {
    background-color: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 20px;
    padding: 1.75rem 1.75rem 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 200ms cubic-bezier(0.22, 1, 0.36, 1),
                transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .program-card:hover {
    border-color: var(--color-coral);
  }
  .program-number {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2.25rem, 3vw, 3rem);
    line-height: 1;
    color: var(--color-coral-deep);
    margin-bottom: 0.25rem;
  }
  .program-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-quiet);
    margin: 0;
  }
  .program-title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(1.375rem, 1.875vw, 1.625rem);
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-navy);
    margin: 0;
    text-wrap: balance;
  }
  .program-tease {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-ink-soft);
    margin: 0.25rem 0 0 0;
    flex: 1;
  }
  .program-link {
    margin-top: 0.875rem;
    align-self: flex-start;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-coral-deep);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .program-link:hover {
    color: var(--color-navy);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .program-foot {
    margin-top: 2.5rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--color-ink-quiet);
  }

  /* Pricing grid + tier list */
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 900px) {
    .pricing-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 4rem;
    }
  }
  .pricing-copy {
    min-width: 0;
  }
  .pricing-tiers {
    background-color: var(--color-paper-soft);
    border-radius: 20px;
    padding: 2rem 1.5rem;
  }
  @media (min-width: 768px) {
    .pricing-tiers {
      padding: 2.5rem 2.25rem;
    }
  }
  .pricing-tier-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .pricing-tier {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--color-rule);
  }
  .pricing-tier:last-child {
    border-bottom: 0;
  }
  .pricing-tier-aside-note {
    margin: 1.5rem 0 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-ink-quiet);
  }
  .pricing-tier-standard {
    background-color: var(--color-info);
    margin: 0.25rem -0.875rem;
    padding: 1rem 0.875rem;
    border-radius: 12px;
    border-bottom: 0;
  }
  .pricing-tier-label {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }
  .pricing-tier-name {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-navy);
  }
  .pricing-tier-note {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-ink-quiet);
  }
  .pricing-tier-amount {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(1.5rem, 2vw, 1.875rem);
    color: var(--color-navy);
    letter-spacing: -0.01em;
    flex: none;
  }
  .pricing-tier-standard .pricing-tier-amount {
    color: var(--color-coral-deep);
  }
  .pricing-text {
    margin: 1.25rem 0 0 0;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-ink-soft);
    max-width: 56ch;
  }

  /* ----- TEACHERS ----- */
  .teachers {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background-color: var(--color-paper);
  }
  @media (min-width: 768px) {
    .teachers {
      padding-top: 7rem;
      padding-bottom: 7rem;
    }
  }

  .teacher-spread {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }
  @media (min-width: 900px) {
    .teacher-spread {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  .teacher {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 480px) {
    .teacher {
      grid-template-columns: 140px 1fr;
      gap: 2rem;
    }
  }
  @media (min-width: 900px) {
    .teacher {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .teacher-photo {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 9999px;
    object-fit: cover;
    background-color: var(--color-paper-soft);
  }
  @media (min-width: 900px) {
    .teacher-photo {
      max-width: 240px;
    }
  }

  .teacher-photo-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-info);
    border: 1.5px dashed oklch(0.7 0.03 261);
  }
  .placeholder-initials {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 500;
    color: var(--color-navy);
    letter-spacing: -0.01em;
  }

  .teacher-name {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    line-height: 1.15;
    color: var(--color-navy);
    margin: 0 0 0.25rem 0;
    letter-spacing: -0.01em;
  }
  .teacher-credential {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-ink-quiet);
    margin: 0 0 1rem 0;
    letter-spacing: 0.01em;
  }
  .teacher-bio {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-ink-soft);
    margin: 0 0 1.25rem 0;
    max-width: 48ch;
  }
  .teacher-link {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-blue);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .teacher-link:hover {
    color: var(--color-navy);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* ----- EXCERPT (Home Stance teaching moment, as a paper artifact) ----- */
  .excerpt {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background-color: var(--color-info);
  }
  @media (min-width: 768px) {
    .excerpt {
      padding-top: 7rem;
      padding-bottom: 7rem;
    }
  }

  .excerpt-page {
    position: relative;
    max-width: 48rem;
    margin: 0 auto;
    background-color: var(--color-paper);
    border-radius: 4px;
    padding: 2.5rem 1.75rem 2.5rem 2.25rem;
    box-shadow:
      0 1px 0 oklch(0 0 0 / 0.04),
      0 2px 6px oklch(0 0 0 / 0.06),
      0 20px 50px -20px oklch(0.27 0.10 261 / 0.25);
    overflow: hidden;
  }
  @media (min-width: 720px) {
    .excerpt-page {
      padding: 4rem 4rem 3.5rem 5rem;
    }
  }

  /* the coral "spine" along the left edge */
  .excerpt-spine {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 6px;
    background-color: var(--color-coral);
  }

  .excerpt-page-header {
    margin-bottom: 1.25rem;
  }
  .excerpt-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-coral-deep);
    margin: 0;
  }

  .excerpt-title {
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--color-navy);
    font-size: clamp(1.875rem, 3vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0 0 1.5rem 0;
    text-wrap: balance;
  }

  .excerpt-body {
    margin: 0;
  }

  .excerpt-text {
    font-family: var(--font-serif);
    font-weight: 400;
    color: var(--color-navy-deep);
    font-size: clamp(1.125rem, 1.4vw, 1.3125rem);
    line-height: 1.6;
    letter-spacing: -0.005em;
    margin: 0 0 1.25rem 0;
    max-width: 62ch;
    text-wrap: pretty;
  }
  .excerpt-text:last-child {
    margin-bottom: 0;
  }

  .excerpt-page-footer {
    margin-top: 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .excerpt-rule {
    display: block;
    width: 3rem;
    height: 1px;
    background-color: var(--color-rule);
  }
  .excerpt-attribution {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    letter-spacing: 0.02em;
    color: var(--color-ink-quiet);
  }
  .excerpt-attribution em {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-ink-soft);
  }

  /* ----- EVALUATION (CHCF), navy ground, the serious moment ----- */
  .evaluation {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background-color: var(--color-navy);
    color: var(--color-on-navy);
  }
  @media (min-width: 768px) {
    .evaluation {
      padding-top: 7rem;
      padding-bottom: 7rem;
    }
  }

  .evaluation-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  @media (min-width: 720px) {
    .evaluation-grid {
      grid-template-columns: 200px 1fr;
      gap: 3.5rem;
    }
  }
  @media (min-width: 1024px) {
    .evaluation-grid {
      grid-template-columns: 240px 1fr;
      gap: 5rem;
    }
  }

  .evaluation-cover img {
    width: 100%;
    max-width: 240px;
    height: auto;
    border-radius: 4px;
    box-shadow:
      0 2px 4px oklch(0 0 0 / 0.25),
      0 16px 40px oklch(0 0 0 / 0.35);
  }

  .evaluation-title {
    font-family: var(--font-serif);
    font-weight: 400;
    color: var(--color-on-navy);
    font-size: clamp(1.875rem, 3.5vw, 2.75rem);
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0;
    text-wrap: balance;
    max-width: 22ch;
  }

  .evaluation-text {
    margin: 1rem 0 1rem 0;
    font-family: var(--font-sans);
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-on-navy-soft);
    max-width: 56ch;
  }
  .evaluation-text + .evaluation-text {
    margin-top: 0.75rem;
  }
  .evaluation-body .btn-on-dark {
    margin-top: 1.25rem;
  }

  /* ----- PRESS (named, not logo soup) ----- */
  .press {
    padding-top: 2rem;
    padding-bottom: 2rem;
    background-color: var(--color-paper);
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
  }
  .press-line {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-ink-quiet);
    text-align: center;
  }
  @media (min-width: 768px) {
    .press-line {
      font-size: 1.05rem;
    }
  }
  .press-label {
    color: var(--color-ink-quiet);
    margin-right: 0.5rem;
    letter-spacing: 0.01em;
  }
  .press-line a {
    color: var(--color-coral-deep);
    text-decoration: none;
    border-bottom: 1px solid oklch(0.68 0.20 21 / 0.4);
    padding-bottom: 1px;
  }
  .press-line a:hover {
    color: var(--color-navy);
    border-bottom-color: var(--color-navy);
  }

  /* ----- SAMPLE LESSON (the primary conversion) ----- */
  .sample {
    padding-top: 6rem;
    padding-bottom: 6rem;
    background-color: var(--color-paper-soft);
    background-image: radial-gradient(
      circle at 80% 20%,
      oklch(0.92 0.012 70) 0%,
      transparent 55%
    );
  }
  @media (min-width: 768px) {
    .sample {
      padding-top: 9rem;
      padding-bottom: 9rem;
    }
  }

  .sample-inner {
    max-width: 76rem;
    margin: 0 auto;
  }
  .sample-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 960px) {
    .sample-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }
  }

  .sample-form {
    max-width: 32rem;
  }

  .sample-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-navy);
    margin: 0.5rem 0 0.5rem 0;
    text-wrap: balance;
  }
  .sample-meta {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--color-ink-quiet);
    margin: 0 0 1.5rem 0;
  }
  .sample-meta em {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-ink-soft);
  }
  .sample-cta-note {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-ink-soft);
    margin: 0 0 2rem 0;
    max-width: 36ch;
  }

  /* artifact tweaks when nested inside .sample (not a standalone section).
     Type and padding scaled down so the page-card height matches the form
     column instead of overflowing it. */
  .sample-excerpt {
    max-width: none;
    margin: 0;
    padding: 2.25rem 1.75rem 2rem 2.5rem;
  }
  @media (min-width: 720px) {
    .sample-excerpt {
      padding: 2.5rem 2.5rem 2.25rem 3rem;
    }
  }
  .sample-excerpt .excerpt-page-header {
    margin-bottom: 0.875rem;
  }
  .sample-excerpt .excerpt-text {
    font-size: clamp(1rem, 1vw, 1.0625rem);
    line-height: 1.55;
    margin-bottom: 0.875rem;
  }
  .sample-excerpt .excerpt-page-footer {
    margin-top: 1.25rem;
    gap: 0.5rem;
  }
  .sample-excerpt .excerpt-attribution {
    font-size: 0.8125rem;
  }

  /* ----- PRICING DOORWAY ----- */
  .pricing-door {
    padding-top: 5rem;
    padding-bottom: 6rem;
    background-color: var(--color-paper);
    background-image: url('/images/topo-dark.svg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  @media (min-width: 768px) {
    .pricing-door {
      padding-top: 7rem;
      padding-bottom: 8rem;
    }
  }
  .pricing-inner {
    max-width: 44rem;
  }
  .pricing-text {
    margin: 1.5rem 0 0 0;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-ink-soft);
    max-width: 60ch;
  }
  .pricing-actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.25rem;
  }
  .pricing-note {
    margin: 1.25rem 0 0 0;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--color-ink-quiet);
    line-height: 1.55;
  }
  .pricing-note a {
    color: var(--color-blue);
  }
  .pricing-es-note {
    margin: 1.25rem 0 0 0;
    padding: 0.85rem 1.1rem;
    background-color: var(--color-paper-soft);
    border: 1px solid var(--color-mint-deep);
    border-radius: 12px;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    color: var(--color-ink-soft);
    line-height: 1.55;
    max-width: 42ch;
  }
  .pricing-es-note a {
    color: var(--color-coral-deep);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }
  .pricing-es-note a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ---------- shared helpers for the new sections ---------- */
  .section-header-center {
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }
  .center-prose {
    margin-left: auto;
    margin-right: auto;
  }
  .title-accent {
    color: var(--color-coral-deep);
  }
  .link-arrow {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-blue);
    text-decoration: none;
  }
  .link-arrow:hover {
    color: var(--color-navy);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* ---------- "What is a Lay Counselor?" ---------- */
  .lay-counselor {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background-color: var(--color-paper);
  }
  @media (min-width: 768px) {
    .lay-counselor {
      padding-top: 7rem;
      padding-bottom: 7rem;
    }
  }
  .lay-counselor-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 900px) {
    .lay-counselor-grid {
      grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
      gap: 5rem;
    }
  }
  .lay-counselor-photo {
    margin: 0;
  }
  .lay-counselor-photo img {
    width: 100%;
    height: auto;
    border-radius: 16px;
    object-fit: cover;
    max-height: 520px;
  }
  .lay-counselor-text {
    margin: 1.25rem 0 1.5rem 0;
    font-family: var(--font-sans);
    font-size: 1.1rem;
    line-height: 1.65;
    color: var(--color-ink-soft);
    max-width: 56ch;
  }

  /* ---------- Course formats, 3 tile grid ---------- */
  .formats {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background-color: var(--color-paper-soft);
  }
  @media (min-width: 768px) {
    .formats {
      padding-top: 7rem;
      padding-bottom: 7rem;
    }
  }
  .format-grid {
    list-style: none;
    margin: 3rem 0 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 960px) {
    .format-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }
  .format-card {
    background-color: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 20px;
    padding: 1.75rem 1.75rem 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 200ms cubic-bezier(0.22, 1, 0.36, 1),
                transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .format-card:hover {
    border-color: var(--color-coral);
  }
  .format-card.is-current {
    background-color: var(--color-navy);
    border-color: var(--color-navy);
    color: var(--color-on-navy);
  }
  .format-card.is-current .format-number {
    color: var(--color-coral);
  }
  .format-card.is-current .format-name {
    color: var(--color-on-navy);
  }
  .format-card.is-current .format-tease {
    color: var(--color-on-navy-soft);
  }
  .format-number {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2.25rem, 3vw, 3rem);
    line-height: 1;
    color: var(--color-coral-deep);
  }
  .format-name {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(1.5rem, 2vw, 1.875rem);
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-navy);
    margin: 0;
  }
  .format-tease {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-ink-soft);
    margin: 0;
    flex: 1;
  }
  .format-link {
    margin-top: 0.5rem;
    align-self: flex-start;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-coral-deep);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .format-link:hover {
    color: var(--color-navy);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .format-current-badge {
    margin-top: 0.5rem;
    align-self: flex-start;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-coral);
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--color-coral);
    border-radius: 9999px;
  }

  /* ---------- Video, lite YouTube poster ---------- */
  .video {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background-color: var(--color-paper);
  }
  @media (min-width: 768px) {
    .video {
      padding-top: 7rem;
      padding-bottom: 7rem;
    }
  }
  .video-wrap {
    max-width: 64rem;
    margin: 0 auto;
    aspect-ratio: 16 / 9;
    border-radius: 16px;
    overflow: hidden;
    box-shadow:
      0 2px 4px oklch(0 0 0 / 0.10),
      0 16px 48px oklch(0 0 0 / 0.18);
    position: relative;
  }
  .video-wrap iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
  .video-poster {
    appearance: none;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 0;
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
    display: block;
  }
  .video-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .video-poster:hover .video-thumb {
    transform: scale(1.02);
  }
  .video-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  .video-play svg {
    filter: drop-shadow(0 2px 8px oklch(0 0 0 / 0.4));
  }
  .video-caption {
    margin-top: 2rem;
    text-align: center;
    max-width: 60rem;
    margin-left: auto;
    margin-right: auto;
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    line-height: 1.4;
    color: var(--color-navy);
    letter-spacing: -0.01em;
  }

  /* ---------- Feature video (self-hosted, near top) ---------- */
  .feature-video {
    padding-top: 4rem;
    padding-bottom: 4rem;
    background-color: var(--color-paper-soft);
  }
  @media (min-width: 768px) {
    .feature-video {
      padding-top: 6rem;
      padding-bottom: 6rem;
    }
  }
  .feature-video-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    max-width: 68rem;
    margin: 0 auto;
  }
  @media (min-width: 900px) {
    .feature-video-grid {
      grid-template-columns: 0.9fr 1.1fr;
      gap: 3.5rem;
    }
    /* video on the left, copy on the right (copy is first in the DOM so it
       leads on mobile) */
    .feature-video-media { grid-column: 1; grid-row: 1; }
    .feature-video-copy  { grid-column: 2; grid-row: 1; }
  }
  .feature-video-heading {
    font-family: var(--font-serif);
    font-weight: 400;
    color: var(--color-navy);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0.75rem 0 0 0;
    text-wrap: balance;
  }
  .feature-video-lead {
    margin: 1.25rem 0 0 0;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-ink-soft);
    max-width: 42ch;
  }
  .feature-video-attr {
    margin: 1.5rem 0 0 0;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-ink-quiet);
  }
  .video-wrap video {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    background-color: var(--color-navy);
  }

  /* ---------- Benefits 2x3 grid ---------- */
  .benefits {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background-color: var(--color-paper-soft);
  }
  @media (min-width: 768px) {
    .benefits {
      padding-top: 7rem;
      padding-bottom: 7rem;
    }
  }
  .benefits-grid {
    list-style: none;
    margin: 3rem 0 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
  }
  @media (min-width: 720px) {
    .benefits-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
  }
  .benefit-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 1.25rem;
    background-color: var(--color-paper);
    border-radius: 12px;
  }
  .benefit-icon {
    flex: none;
    width: 32px;
    height: 32px;
    display: inline-flex;
  }
  .benefit-text {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.5;
    color: var(--color-ink-soft);
  }

  /* ---------- Inside the course, feature list ---------- */
  .inside {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background-color: var(--color-paper);
  }
  @media (min-width: 768px) {
    .inside {
      padding-top: 7rem;
      padding-bottom: 7rem;
    }
  }
  .inside-grid {
    list-style: none;
    margin: 3rem 0 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 720px) {
    .inside-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.75rem 2rem;
    }
    /* Last tile spans full width so an odd item count still looks tidy */
    .inside-grid > .inside-item:last-child {
      grid-column: 1 / -1;
    }
  }
  .inside-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
    align-items: start;
    padding: 1.5rem 1.5rem;
    background-color: var(--color-paper-soft);
    border-radius: 16px;
  }
  @media (min-width: 768px) {
    .inside-item {
      padding: 1.875rem 1.875rem;
      gap: 1.5rem;
    }
  }
  .inside-icon {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background-color: var(--color-paper);
    color: var(--color-navy);
    border: 1px solid var(--color-rule);
  }
  .inside-body {
    min-width: 0;
  }
  .inside-name {
    margin: 0 0 0.375rem 0;
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(1.1875rem, 1.5vw, 1.375rem);
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-navy);
    text-wrap: balance;
  }
  .inside-text {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-ink-soft);
  }

  /* ---------- Testimonial pull quote ---------- */
  .testimonial {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background-color: var(--color-paper);
  }
  @media (min-width: 768px) {
    .testimonial {
      padding-top: 7rem;
      padding-bottom: 7rem;
    }
  }
  .testimonial-block {
    max-width: 52rem;
    margin: 0 auto;
    text-align: center;
  }
  .testimonial-quote {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.35;
    color: var(--color-navy);
    letter-spacing: -0.015em;
    text-wrap: pretty;
  }
  .testimonial-quote::before {
    content: "\201C";
  }
  .testimonial-quote::after {
    content: "\201D";
  }
  .testimonial-attribution {
    margin: 1.5rem 0 0 0;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--color-ink-quiet);
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
  }

  /* ---------- Organizational testimonials (navy band) ---------- */
  .org-testimonials {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background-color: var(--color-navy);
    background-image: url('/images/topo-light.svg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  @media (min-width: 768px) {
    .org-testimonials {
      padding-top: 7rem;
      padding-bottom: 7rem;
    }
  }
  .org-testimonials .eyebrow { color: var(--color-coral); }
  .org-testimonials .section-title { color: var(--color-on-navy); }
  .org-testimonials .title-accent { color: var(--color-coral); }
  .org-testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 68rem;
    margin: 0 auto;
  }
  @media (min-width: 860px) {
    .org-testimonials-grid {
      grid-template-columns: 0.85fr 1.15fr;
      gap: 2rem;
      align-items: start;
    }
  }
  .org-testimonial {
    position: relative;
    margin: 0;
    background-color: oklch(1 0 0 / 0.05);
    border: 1px solid oklch(1 0 0 / 0.12);
    border-radius: 16px;
    padding: 1.75rem 1.75rem 1.5rem;
  }
  @media (min-width: 768px) {
    .org-testimonial {
      padding: 2.25rem 2.25rem 2rem;
    }
  }
  /* coral opening-quote glyph as the brand accent (replaces a side stripe) */
  .org-testimonial::before {
    content: "\201C";
    position: absolute;
    top: 0.35rem;
    left: 1.25rem;
    font-family: var(--font-serif);
    font-size: 3rem;
    line-height: 1;
    color: var(--color-coral);
  }
  .org-testimonial-quote {
    margin: 1.75rem 0 0 0;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-on-navy-soft);
    max-width: 62ch;
  }
  .org-testimonial-quote p {
    margin: 0;
  }
  .org-testimonial-quote p + p {
    margin-top: 0.85rem;
  }
  .org-testimonial-attribution {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid oklch(1 0 0 / 0.14);
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-sans);
  }
  .org-testimonial-cite {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .org-testimonial-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-on-navy);
  }
  .org-testimonial-org {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-on-navy-quiet);
  }

  /* ---------- Press section, logos + article list ---------- */
  .press {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background-color: var(--color-paper);
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
  }
  @media (min-width: 768px) {
    .press {
      padding-top: 7rem;
      padding-bottom: 7rem;
    }
  }
  /* Press logo strip, real publication logos, normalized to similar visual weight */
  .press-logos {
    margin-top: 3rem;
    margin-bottom: 3rem;
    padding: 1.75rem 1.25rem;
    background-color: var(--color-paper-soft);
    border-radius: 16px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1.25rem 2rem;
  }
  @media (min-width: 768px) {
    .press-logos {
      padding: 2.25rem 2rem;
      gap: 1.5rem 2.5rem;
    }
  }
  .press-logo {
    display: inline-flex;
    align-items: center;
    height: auto;
    width: auto;
    flex: none;
  }
  /* Logos sized by height so they sit on a common visual baseline.
     Each publication's logo has a different aspect ratio, so per-logo
     heights compensate. */
  .press-logo-chcf {
    height: 32px;
  }
  .press-logo-stat {
    height: 32px;
  }
  .press-logo-modbee {
    font-family: Georgia, "Times New Roman", serif;
    font-weight: 700;
    font-style: italic;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-navy);
    letter-spacing: -0.01em;
    user-select: none;
  }
  .press-logo-steinberg {
    height: 40px;
  }
  .press-logo-healthline {
    height: 26px;
  }
  @media (min-width: 768px) {
    .press-logo-chcf {
      height: 36px;
    }
    .press-logo-stat {
      height: 36px;
    }
    .press-logo-modbee {
      font-size: 1.75rem;
    }
    .press-logo-steinberg {
      height: 48px;
    }
    .press-logo-healthline {
      height: 30px;
    }
  }
  .press-logo-divider {
    width: 1px;
    height: 32px;
    background-color: var(--color-rule);
    display: none;
  }
  @media (min-width: 768px) {
    .press-logo-divider {
      display: block;
    }
  }
  .press-articles {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-rule);
  }
  .press-article {
    border-bottom: 1px solid var(--color-rule);
  }
  .press-article-link {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    column-gap: 1rem;
    row-gap: 0.25rem;
    padding: 1.25rem 0;
