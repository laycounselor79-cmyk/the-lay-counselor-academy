<script>
  // Lite YouTube embed: swap the poster button for an iframe on click,
  // so the iframe (and its ~300KB of YT JS) only loads when the user opts in.
  document.querySelectorAll<HTMLElement>("[data-video-id]").forEach((wrap) => {
    const id = wrap.getAttribute("data-video-id");
    if (!id) return;
    const trigger = wrap.querySelector<HTMLButtonElement>("[data-video-trigger]");
    if (!trigger) return;
    trigger.addEventListener("click", () => {
      const iframe = document.createElement("iframe");
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      iframe.title = "Co-Creators Elizabeth Morrison and Alli Moreno share the story of The Lay Counselor Academy";
      iframe.setAttribute("frameborder", "0");
      iframe.setAttribute("allow", "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture");
      iframe.setAttribute("allowfullscreen", "");
      wrap.replaceChildren(iframe);
    });
  });
</script>
