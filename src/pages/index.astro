---
import Layout from "../layouts/Layout.astro";
import SampleLessonForm from "../components/SampleLessonForm.astro";

const modules = [
  {
    n: "1",
    title: "What lay counseling is, why we need lay counselors now more than ever.",
    tease:
      "How biases and judgments can damage our relationships with others, and what we can do to mitigate our own.",
  },
  {
    n: "2",
    title: "Core Counseling Approaches",
    tease:
      "What we call 'Home Stance': the essential techniques we use over and over again: warm tone and body language, open-ended questions, empathic reflection, affirming strengths, and the practice of countering shame. Plus, strength-based counseling approaches.",
  },
  {
    n: "3",
    title: "Helping people with thoughts that are causing suffering (CBT).",
    tease:
      "How to recognize anxiety and depression, and practical strategies to help others who are suffering with these conditions.",
  },
  {
    n: "4",
    title: "Staying on what we call 'Fertile Ground'; ensuring we guide people toward the most helpful things to share about.",
    tease:
      "Using positive psychology to help others build up their happiness practices.",
  },
  {
    n: "5",
    title: "Recognizing addiction and using motivational interviewing to help people make changes.",
    tease:
      "How to help when someone shares difficult childhood experiences, and how to protect ourselves from vicarious trauma.",
  },
  {
    n: "6",
    title: "How to ask about suicidal thoughts and what we can do to help.",
    tease:
      "Cultural humility and helping others understand their identities.",
  },
  {
    n: "7",
    title: "Practical boundaries guidance (including when and when not to self-disclose) to ensure safety for those we are helping and ourselves.",
    tease:
      "How do we end a counseling relationship with care, ensuring those we are helping have a healthy goodbye with us.",
  },
];

const pressLinks = [
  {
    name: "California Healthline",
    href: "https://californiahealthline.org/news/article/asian-lay-counseling-mental-health-therapist-shortage-oakland-california/",
    title: "Asian Health Center Tries Unconventional Approach to Counseling",
  },
  {
    name: "STAT News",
    href: "https://www.statnews.com/2024/01/18/mental-health-therapist-shortage-lay-counselors-needed/",
    title: "Amid a dire nationwide therapist shortage, could lay counselors help close the gap?",
  },
  {
    name: "the Modesto Bee",
    href: "https://www.modbee.com/news/local/article275363006.html",
    title: "Severe shortage of mental health clinicians prompts Stanislaus County to try bold approach",
  },
  {
    name: "the Steinberg Institute",
    href: "https://steinberginstitute.org/champion/elizabeth-morrison-and-alli-moreno/",
    title: "2023 Steinberg Institute Champions: Elizabeth Morrison & Alli Moreno",
  },
  {
    name: "CHCF Blog",
    href: "https://www.chcf.org/blog/new-workforce-lay-counselors-strives-bridge-mental-health-care-gaps/",
    title: "New Workforce of Lay Counselors Strives to Bridge Mental Health Care Gaps",
  },
];

const courseFormats = [
  {
    n: "01",
    name: "The LCA: Self-Paced",
    tease:
      "Our fully asynchronous course, giving you foundational mental health counseling skills on your own schedule. The course is deep and wide, with essential information on core counseling skills to help those with anxiety, depression, substance use struggles, and more.",
    href: "#sample",
    cta: "You are here",
    current: true,
  },
  {
    n: "02",
    name: "The LCA: Live",
    tease:
      "Our flagship course. Fourteen weeks of live, practice-based learning with a cohort of peers. The LCA Live is delivered virtually, and includes 5 personal counseling sessions.",
    href: "/contact/",
    cta: "Contact us to register",
    current: false,
  },
  {
    n: "03",
    name: "CHW Certification, with a Mental Health Counseling emphasis.",
    tease:
      "Community Health Worker certification in California, with an emphasis on mental health counseling. Learn all CHW core competencies plus essential mental health counseling skills.",
    href: "/contact/",
    cta: "Contact us to register",
    current: false,
  },
];

const benefits = [
  "If you work in human services as a Community Health Worker, SUD counselor, case manager, health navigator, or similar position…",
  "If you work in a school system, are a first responder, or a faith leader… do crisis work.",
  "If you work in human resources, medical systems, or are a barber or stylist…",
  "If you are serving people in your community who have little or no access to high-quality, culturally concordant mental health counseling.",
  "If you are a helper at heart, and are passionate about supporting others.",
  "If you are busy and need a flexible course that you can complete at your own pace, when it is convenient for you!",
];

const downloads = [
  {
    title: "LCA Course Options",
    thumb: "/images/pdf-thumb-course-options.webp",
    href: "/downloads/LCA_Course_Options.pdf",
    external: false,
  },
  {
    title: "LCA Self-Paced FAQs",
    thumb: "/images/pdf-thumb-self-paced-faq.webp",
    href: "/downloads/LCA_Self_Paced_FAQs.pdf",
    external: false,
  },
  {
    title: "LCA Self-Paced Details",
    thumb: "/images/pdf-thumb-self-paced.webp",
    href: "/downloads/LCA_Self_Paced_QR.pdf",
    external: false,
  },
];
---

<Layout
  title="Mental health counseling course, The Lay Counselor Academy"
  extraSchemas={[{
    "@context": "https://schema.org",
    "@type": "VideoObject",
    name: "The story of The Lay Counselor Academy",
    description: "Co-Creators Elizabeth Morrison and Alli Moreno share the story and mission behind The Lay Counselor Academy.",
    thumbnailUrl: "https://img.youtube.com/vi/5c1knT6_ejs/maxresdefault.jpg",
    uploadDate: "2024-01-01T08:00:00-08:00",
    contentUrl: "https://www.youtube.com/watch?v=5c1knT6_ejs",
    embedUrl: "https://www.youtube-nocookie.com/embed/5c1knT6_ejs",
    publisher: { "@id": "https://thelaycounseloracademy.com/#organization" },
  }, {
    "@context": "https://schema.org",
    "@type": "VideoObject",
    name: "Why Lay Counseling Matters Now",
    description: "Elizabeth Morrison, Co-Creator of The Lay Counselor Academy, on why the world needs more skilled helpers right now.",
    thumbnailUrl: "https://thelaycounseloracademy.com/images/why-lay-counseling-matters-now-poster.webp",
    uploadDate: "2026-07-02T09:00:00-07:00",
    duration: "PT51S",
    contentUrl: "https://thelaycounseloracademy.com/video/why-lay-counseling-matters-now.mp4",
    publisher: { "@id": "https://thelaycounseloracademy.com/#organization" },
  }, {
    "@context": "https://schema.org",
    "@type": "Review",
    itemReviewed: { "@id": "https://thelaycounseloracademy.com/#course" },
    reviewBody: "Hands down the most valuable course I've ever taken. I use the mental health counseling skills I learned in the LCA every day, with my patients but also at home!",
    author: {
      "@type": "Person",
      name: "Oscar",
      jobTitle: "Community Health Worker",
      description: "LCA graduate",
    },
  }, {
    "@context": "https://schema.org",
    "@type": "Review",
    itemReviewed: { "@id": "https://thelaycounseloracademy.com/#course" },
    reviewBody: "The Lay Counselor Academy changed everything for us. The wait time for a behavioral health visit was reduced from 3-4 months to 1 week. I receive fewer SOS calls from my colleagues about patients in crisis. And now we have enough Spanish-speaking staff to provide our patients with mental health care in their native languages!",
    author: {
      "@type": "Person",
      name: "Dr. Guarav Mishra",
      jobTitle: "CBHO",
      worksFor: { "@type": "Organization", name: "San Ysidro Health Centers" },
    },
  }, {
    "@context": "https://schema.org",
    "@type": "Review",
    itemReviewed: { "@id": "https://thelaycounseloracademy.com/#course" },
    reviewBody: "I continue to be amazed by the impact the Lay Counselor Academy has had on our team. Time and again, I hear from employees who describe the experience as transformative. They talk about how much they have learned, the confidence they have gained, and how much better prepared they feel to support patients experiencing mental health challenges. Over the past four years, Hill Country Community Clinic has sent more than 50 employees through the Lay Counselor Academy. By equipping our case and care managers and SUD teams with evidence-based counseling skills, we are expanding access to care in meaningful ways. Our patients don't always have to wait weeks for an appointment with a licensed clinician. Because of the LCA course, they can receive support, encouragement, and practical tools when they need them most. The benefits extend beyond our patients. Staff consistently report greater job satisfaction, increased confidence in their roles, and reduced feelings of burnout. Our supervisors have also noticed a difference, receiving fewer crisis calls from support staff because employees feel better equipped to respond effectively and compassionately. For an organization like Hill Country, which strives to meet people where they are and provide whole-person care, the Lay Counselor Academy has been an invaluable investment in both our workforce and those we serve.",
    author: {
      "@type": "Person",
      name: "Jo Campbell",
      jobTitle: "CEO",
      worksFor: { "@type": "Organization", name: "Hill Country Community Clinic" },
    },
  }]}
>
  {/* -----------------------------------------------------------------------
       Hero
       --------------------------------------------------------------------- */}
  <section class="hero" aria-labelledby="hero-title">
    <div class="page-container">
      <div class="hero-grid">
        <div class="hero-content">
          <p class="hero-kicker">
            <span class="marker-coral" aria-hidden="true"></span>
            A how-to course on mental health counseling.
          </p>

          <h1 id="hero-title" class="hero-title hero-fade">
            Learn essential mental health counseling skills.
          </h1>

          <p class="hero-subhead">
            A self-paced course for everyone who wants to be a better helper.
            Taught by deeply experienced licensed clinicians and lay counselors.
          </p>

          <div class="hero-actions">
            <a class="btn-primary" href="#sample">
              Read the sample article
            </a>
            <a class="hero-enroll-link" href="https://app.teachfloor.com/the-lay-counselor-academy/c/32305" rel="noopener">
              or enroll now
              <span aria-hidden="true" class="arrow">→</span>
            </a>
          </div>

          <p class="hero-cta-note">
            It's &lsquo;Advice: Why &amp; How We Avoid It,&rsquo; from Module 2 of
            the course.
          </p>
        </div>

        <figure class="hero-photo">
          <img
            src="/images/hero-counseling-2.webp"
            alt="A lay counselor speaking and gesturing with her hand on her heart during a session"
            width="537"
            height="557"
            class="hero-photo-img"
            loading="eager"
            fetchpriority="high"
          />
        </figure>
      </div>

      <div class="hero-trust-panel" aria-label="Featured in">
        <span class="hero-trust-panel-label">Featured in</span>
        <div class="hero-trust-panel-logos">
          <a class="hero-trust-link" href="https://www.chcf.org/publication/lay-counselor-academy-evaluation-strengthening-behavioral-health-workforce/" rel="noopener" target="_blank" aria-label="Read the California Health Care Foundation evaluation of The Lay Counselor Academy">
            <img src="/images/press/chcf-on-navy.png" alt="California Health Care Foundation" width="880" height="120" class="hero-trust-logo hero-trust-logo-chcf" loading="eager" />
          </a>
          <a class="hero-trust-link" href="https://www.statnews.com/2024/01/18/mental-health-therapist-shortage-lay-counselors-needed/" rel="noopener" target="_blank" aria-label="Read the STAT News article on the therapist shortage and lay counselors">
            <img src="/images/press/stat-on-navy.svg" alt="STAT News" width="516" height="100" class="hero-trust-logo hero-trust-logo-stat" loading="eager" />
          </a>
          <a class="hero-trust-link" href="https://www.modbee.com/news/local/article275363006.html" rel="noopener" target="_blank" aria-label="Read the Modesto Bee article on Stanislaus County's lay counselor approach">
            <span class="hero-trust-logo hero-trust-logo-modbee">The Modesto Bee</span>
          </a>
          <a class="hero-trust-link" href="https://steinberginstitute.org/champion/elizabeth-morrison-and-alli-moreno/" rel="noopener" target="_blank" aria-label="Read the Steinberg Institute profile of Elizabeth Morrison and Alli Moreno">
            <img src="/images/press/steinberg-on-navy.png" alt="Steinberg Institute" width="721" height="157" class="hero-trust-logo hero-trust-logo-steinberg" loading="eager" />
          </a>
          <a class="hero-trust-link" href="https://californiahealthline.org/news/article/asian-lay-counseling-mental-health-therapist-shortage-oakland-california/" rel="noopener" target="_blank" aria-label="Read the California Healthline article on lay counseling and the therapist shortage">
            <img src="/images/press/healthline-on-navy.svg" alt="California Healthline" width="443" height="53" class="hero-trust-logo hero-trust-logo-healthline" loading="eager" />
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* -----------------------------------------------------------------------
       Feature video, self-hosted "Why Lay Counseling Matters Now".
       Two-column: context copy alongside the clip so it has a lead-in and
       sits at a contained size. Native <video>, preload="none" + branded
       poster so the 13MB file only downloads on play.
       --------------------------------------------------------------------- */}
  <section class="feature-video" aria-labelledby="feature-video-title">
    <div class="page-container">
      <div class="feature-video-grid">
        <div class="feature-video-copy">
          <p class="eyebrow">A word from our co-creator</p>
          <h2 id="feature-video-title" class="feature-video-heading">
            Why lay counseling <span class="title-accent">matters now.</span>
          </h2>
          <p class="feature-video-lead">
            In just under a minute, Elizabeth Morrison shares why the world
            needs more skilled everyday helpers, and how this course prepares
            you to become one.
          </p>
          <p class="feature-video-attr">
            <span class="marker-coral" aria-hidden="true"></span>
            Elizabeth Morrison, PhD, LCSW, Co-Creator of the LCA
          </p>
        </div>
        <div class="feature-video-media">
          <div class="video-wrap">
            <video
              class="feature-video-el"
              data-video-title="Why Lay Counseling Matters Now"
              controls
              preload="none"
              playsinline
              poster="/images/why-lay-counseling-matters-now-poster.webp"
              width="1920"
              height="1080"
            >
              <source src="/video/why-lay-counseling-matters-now.mp4" type="video/mp4" />
              Your browser doesn&rsquo;t support embedded video.
              <a href="/video/why-lay-counseling-matters-now.mp4">Download the video</a>.
            </video>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* -----------------------------------------------------------------------
       Framing paragraph, two-column with the LCA cohort photo on the right
       --------------------------------------------------------------------- */}
  <section class="framing reveal" aria-label="Who this program is for">
    <div class="page-container">
      <div class="framing-grid">
        <div class="framing-prose">
          <p class="framing-text">
            You're probably the person in your family, community or friend
            group who people turn to when they need support; you've likely been told
            you are easy to talk to. This means you're an empathic, skillful
            listener! This course will build on the skills you already have,
            deepen your understanding of mental health conditions, and give
            you practical counseling skills to help others even more.
          </p>
          <p class="framing-aside">
            Become the best helper you can be, at a time when the world needs
            you most.
          </p>
        </div>
        <figure class="framing-photo">
          <img
            src="/images/hero-counseling-900.webp"
            alt="A cohort of Lay Counselor Academy graduates standing together after their training"
            width="900"
            height="329"
            class="framing-photo-img"
            loading="lazy"
          />
          <figcaption class="framing-photo-caption">
            Graduation day at one of our in-person courses!
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  {/* -----------------------------------------------------------------------
       What is a Lay Counselor, short definition + portrait
       --------------------------------------------------------------------- */}
  <section class="lay-counselor reveal" aria-labelledby="lay-counselor-title">
    <div class="page-container">
      <div class="lay-counselor-grid">
        <figure class="lay-counselor-photo">
          <img
            src="/images/what-is-lay-counselor.webp"
            alt="A community health worker in a moment of conversation"
            width="540"
            height="600"
            loading="lazy"
          />
        </figure>
        <div class="lay-counselor-body">
          <h2 id="lay-counselor-title" class="section-title">
            What is <span class="title-accent">lay counseling?</span>
          </h2>
          <p class="lay-counselor-text">
            Lay counseling is mental health counseling, delivered by helpers
            who have learned the skills outside of the conventional academic
            and licensure pathways. They sit with people in hard moments and
            offer empathic, evidence-based care, bridging gaps that licensed
            clinicians alone cannot fill.
          </p>
          <a class="link-arrow" href="https://www.emorrisonconsulting.com/what-is-a-lay-counselor/" rel="noopener">
            Learn more
            <span aria-hidden="true" class="arrow">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* -----------------------------------------------------------------------
       Course formats, 4 tiles. Self-Paced highlighted as the current page.
       --------------------------------------------------------------------- */}
  <section id="formats" class="formats reveal" aria-labelledby="formats-title">
    <div class="page-container">
      <header class="section-header section-header-center">
        <p class="eyebrow">Courses and certificates</p>
        <h2 id="formats-title" class="section-title">
          What is the <span class="title-accent">Lay Counselor Academy?</span>
        </h2>
        <p class="section-lede center-prose">
          The LCA is a course that equips you with practical skills in mental
          health counseling.
        </p>
      </header>

      <ol class="format-grid" aria-label="Course formats">
        {courseFormats.map((fmt) => (
          <li class={`format-card ${fmt.current ? "is-current" : ""}`}>
            <span class="format-number" aria-hidden="true">{fmt.n}</span>
            <h3 class="format-name">{fmt.name}</h3>
            <p class="format-tease">{fmt.tease}</p>
            {fmt.current ? (
              <span class="format-current-badge">You are here</span>
            ) : (
              <a class="format-link" href={fmt.href} {...(fmt.href.startsWith("http") ? { rel: "noopener" } : {})}>
                {fmt.cta}
                <span aria-hidden="true" class="arrow">→</span>
              </a>
            )}
          </li>
        ))}
      </ol>
    </div>
  </section>

  {/* -----------------------------------------------------------------------
       Video, Co-Creators of LCA share the story.
       Direct iframe with loading="lazy" and a YouTube nocookie embed.
       Simple, reliable, no JS required.
       --------------------------------------------------------------------- */}
  <section class="video reveal" aria-labelledby="video-title">
    <div class="page-container">
      <div class="video-wrap">
        <iframe
          src="https://www.youtube-nocookie.com/embed/5c1knT6_ejs?rel=0"
          title="Co-Creators Elizabeth Morrison and Alli Moreno share the story of The Lay Counselor Academy"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          referrerpolicy="strict-origin-when-cross-origin"
        ></iframe>
      </div>
      <h2 id="video-title" class="video-caption">
        Listen to Co-Creators <span class="title-accent">Elizabeth Morrison &amp; Alli Moreno</span> share the story and the mission behind The Lay Counselor Academy.
      </h2>
    </div>
  </section>

  {/* -----------------------------------------------------------------------
       Teachers, placed right after the video so readers who just watched
       Elizabeth and Alli speak can now meet them statically with bios.
       --------------------------------------------------------------------- */}
  <section id="co-creators-and-faculty" class="teachers reveal" aria-label="Co-creators and faculty">
    <div class="page-container">
      <header class="section-header">
        <p class="eyebrow">Faculty</p>
        <p class="section-lede">
          The academy is small on purpose. You learn from people who are still
          doing the work, not from a faceless platform.
        </p>
      </header>

      <div class="teacher-spread">
        <article class="teacher">
          <img
            src="/images/elizabeth-headshot.webp"
            alt="Photograph of Elizabeth Morrison"
            width="320"
            height="320"
            class="teacher-photo"
            loading="lazy"
          />
          <div class="teacher-body">
            <h3 class="teacher-name">Elizabeth Morrison</h3>
            <p class="teacher-credential">PhD, LCSW, MAC. Co-creator of the LCA and licensed clinician.</p>
            <p class="teacher-bio">
              Elizabeth has a Doctorate in Psychology, is a Licensed Clinical
              Social Worker, and has a Master of Addiction Counseling. She has
              been a practicing therapist for over 30 years, working in
              addiction treatment settings, primary care systems, and specialty
              care clinics. She is passionate about expanding access to mental
              health care by training trusted community members to provide
              mental health counseling.
            </p>
            <a class="teacher-link" href="/teachers/elizabeth-morrison/">
              Read more about Elizabeth
              <span aria-hidden="true" class="arrow">→</span>
            </a>
          </div>
        </article>

        <article class="teacher">
          <img
            src="/images/alli-moreno-headshot.webp"
            alt="Photograph of Alli Moreno"
            width="360"
            height="360"
            class="teacher-photo"
            loading="lazy"
          />
          <div class="teacher-body">
            <h3 class="teacher-name">Alli Moreno</h3>
            <p class="teacher-credential">Alli is the Co-Creator of the LCA and a Lay Counselor.</p>
            <p class="teacher-bio">
              Alli co-created The Lay Counselor Academy with Elizabeth. Like
              most lay counselors, Alli was naturally skilled and built on this
              with more training, continual learning, and practice. She is
              passionate about elevating and supporting community members who
              are already providing mental health support to the people they
              serve.
            </p>
            <a class="teacher-link" href="/teachers/alli-moreno/">
              Read more about Alli
              <span aria-hidden="true" class="arrow">→</span>
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  {/* -----------------------------------------------------------------------
       Benefits, 2x3 grid of why-lay-counselors. Card grid, authorized as
       parent-brand-continuity exception to impeccable's no-card-grid rule.
       --------------------------------------------------------------------- */}
  <section class="benefits reveal" aria-labelledby="benefits-title">
    <div class="page-container">
      <header class="section-header section-header-center">
        <p class="eyebrow">Who it's for</p>
        <h2 id="benefits-title" class="section-title">
          Is the Lay Counselor Academy <span class="title-accent">for me?</span>
        </h2>
        <p class="section-lede center-prose">
          Are you often talking to people who share their mental health
          struggles with you? Then the answer is yes!
        </p>
      </header>

      <ul class="benefits-grid" aria-label="Is this for me?">
        {benefits.map((b) => (
          <li class="benefit-item">
            <span class="benefit-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="32" height="32">
                <circle cx="16" cy="16" r="16" fill="var(--color-blue)"/>
                <path d="M22.4 9.9c-0.6-0.3-1.3 0.3-1.7 0.7-1 1-1.8 2-2.7 3-1 1.1-1.9 2.1-3 3.2-0.6 0.6-1.2 1.2-1.6 1.9-0.9-0.9-1.6-1.8-2.6-2.5-0.7-0.5-1.9-0.9-1.9 0.4 0 1.7 1.5 3.5 2.6 4.6 0.5 0.5 1.1 1 1.8 1 0.9 0 1.7-1 2.2-1.6 0.9-1 1.7-2 2.5-3 1.1-1.3 2.2-2.6 3.2-4 0.7-0.8 2.7-2.8 1.2-3.7z" fill="#fff"/>
              </svg>
            </span>
            <p class="benefit-text">{b}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* -----------------------------------------------------------------------
       Testimonial, a single pull quote, not a carousel.
       --------------------------------------------------------------------- */}
  <section class="testimonial reveal" aria-label="A graduate's experience">
    <div class="page-container">
      <figure class="testimonial-block">
        <blockquote class="testimonial-quote">
          Hands down the most valuable course I've ever taken. I use the
          mental health counseling skills I learned in the LCA every day, with
          my patients but also at home!
        </blockquote>
        <figcaption class="testimonial-attribution">
          <span class="marker-coral" aria-hidden="true"></span>
          Oscar, Community Health Worker and LCA graduate.
        </figcaption>
      </figure>
    </div>
  </section>

  {/* -----------------------------------------------------------------------
       Organizational testimonials, provided by the client (July 2026).
       Named quotes from partner health organizations. Verbatim.
       --------------------------------------------------------------------- */}
  <section class="org-testimonials reveal" aria-labelledby="org-testimonials-title">
    <div class="page-container">
      <header class="section-header section-header-center">
        <p class="eyebrow">From the organizations we train</p>
        <h2 id="org-testimonials-title" class="section-title">
          What it looks like <span class="title-accent">at scale.</span>
        </h2>
      </header>

      <div class="org-testimonials-grid">
