---
import Layout from "../../layouts/Layout.astro";

const formats = [
  {
    name: "LCA A tu propio ritmo",
    price: "$1,200",
    desc: "Totalmente asíncrono. Empieza cuando quieras, avanza a tu ritmo.",
    rows: {
      live: "0",
      flexibleStart: "Sí, cuando quieras",
      pairedPractice: "No",
      groupPractices: "No",
      personalCounseling: "No",
      observation: "No",
      certificate: "Sí, al completarlo",
    },
    cta: "Lee el artículo de muestra",
    href: "/es/#sample",
    current: true,
  },
  {
    name: "LCA En vivo",
    price: "$5,500",
    desc: "Catorce sesiones en vivo con una cohorte, más consejería personal.",
    rows: {
      live: "14 sesiones",
      flexibleStart: "No, por cohortes",
      pairedPractice: "Durante las sesiones en vivo",
      groupPractices: "Sí",
      personalCounseling: "5 sesiones incluidas",
      observation: "Sí",
      certificate: "Sí",
    },
    cta: "Contáctanos para registrarte",
    href: "/es/contact/",
    current: false,
  },
];

const rowOrder: Array<[keyof typeof formats[number]["rows"], string]> = [
  ["live", "Sesiones en vivo"],
  ["flexibleStart", "Fechas de inicio flexibles"],
  ["pairedPractice", "Práctica en parejas"],
  ["groupPractices", "Prácticas grupales"],
  ["personalCounseling", "Sesiones de consejería personal"],
  ["observation", "Observación y retroalimentación"],
  ["certificate", "Certificado"],
];

const pricingFaqs: Array<{ q: string; a: string }> = [
  {
    q: "¿Puedo inscribir a todo mi equipo u organización?",
    a: "Sí. Muchos de nuestros participantes llegan a través de su empleador: agencias de salud conductual del condado, cuerpos de bomberos, escuelas, comunidades de fe, trabajadores de salud comunitaria y organizaciones sin fines de lucro. Ofrecemos precios por volumen para grupos. Escribe a Angelica a Angelica@emorrisonconsulting.com con el número aproximado de personas y te responderá en un día hábil.",
  },
  {
    q: "¿Cuál es la diferencia entre los cursos A tu propio ritmo y En vivo?",
    a: "A tu propio ritmo es el curso principal de setenta horas, totalmente asíncrono, con fechas de inicio flexibles. En vivo son catorce sesiones en vivo a lo largo de catorce semanas con una cohorte de pares, más cinco sesiones de consejería personal incluidas. Ambos llevan a la misma habilidad fundamental, A tu propio ritmo es para quien quiere avanzar a su ritmo; En vivo es para quien quiere práctica y retroalimentación con personas.",
  },
];
---

<Layout
  lang="es"
  title="Precios, La Academia del Consejero Laico"
  description="Precios LCA. Curso A tu propio ritmo $1,200, acceso de por vida. Cohorte En vivo $5,500 a lo largo de 14 semanas. Tarifas para organizaciones."
  extraSchemas={[{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": "https://thelaycounseloracademy.com/es/pricing/#faqpage",
    inLanguage: "es",
    speakable: {
      "@type": "SpeakableSpecification",
      xpath: ["//main//h1", "//main//h3[@class='pricing-faq-question']"],
    },
    mainEntity: pricingFaqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  }]}
>
  <section class="page-hero" aria-labelledby="page-hero-title">
    <div class="page-container">
      <p class="eyebrow eyebrow-on-dark">Cuánto cuesta</p>
      <h1 id="page-hero-title" class="page-hero-title">
        Dos formas de aprender. <span class="title-accent">El mismo oficio.</span>
      </h1>
      <p class="page-hero-lede">
        El curso A tu propio ritmo es totalmente asíncrono y cuesta $1,200
        con acceso de por vida. La cohorte En vivo cuesta $5,500 a lo largo
        de catorce semanas e incluye cinco sesiones de consejería personal.
        Hay tarifas para organizaciones disponibles.
      </p>
    </div>
  </section>

  <section class="pricing-compare" aria-labelledby="pricing-compare-title">
    <div class="page-container">
      <header class="section-header section-header-center">
        <p class="eyebrow">Ambos formatos</p>
        <h2 id="pricing-compare-title" class="section-title">
          A tu propio ritmo o En vivo. <span class="title-accent">Elige el que te encaje.</span>
        </h2>
      </header>

      <ol class="format-compare">
        {formats.map((fmt) => (
          <li class={`format-compare-card ${fmt.current ? "format-compare-card-current" : ""}`}>
            <div class="format-compare-head">
              <h3 class="format-compare-name">{fmt.name}</h3>
              <span class="format-compare-price">{fmt.price}</span>
              <p class="format-compare-desc">{fmt.desc}</p>
            </div>

            <dl class="format-compare-rows">
              {rowOrder.map(([key, label]) => (
                <div class="format-compare-row">
                  <dt>{label}</dt>
                  <dd>{fmt.rows[key]}</dd>
                </div>
              ))}
            </dl>

            {fmt.current ? (
              <span class="format-compare-here">Estás aquí</span>
            ) : (
              <a
                class="btn-secondary format-compare-cta"
                href={fmt.href}
                {...(fmt.href.startsWith("http") ? { rel: "noopener" } : {})}
              >
                {fmt.cta}
                <span aria-hidden="true" class="arrow">→</span>
              </a>
            )}
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="pricing-faq" aria-labelledby="pricing-faq-title">
    <div class="page-container">
      <header class="section-header section-header-center">
        <p class="eyebrow">Preguntas frecuentes</p>
        <h2 id="pricing-faq-title" class="section-title">
          Dos cosas que la gente pregunta <span class="title-accent">antes de comprar.</span>
        </h2>
      </header>

      <ol class="pricing-faq-list">
        {pricingFaqs.map((f, i) => (
          <li class="pricing-faq-item">
            <p class="pricing-faq-number" aria-hidden="true">{String(i + 1).padStart(2, "0")}</p>
            <div class="pricing-faq-body">
              <h3 class="pricing-faq-question">{f.q}</h3>
              <p class="pricing-faq-answer">{f.a}</p>
            </div>
          </li>
        ))}
      </ol>

      <p class="pricing-faq-more">
        <a href="/es/faq/">Ver todas las preguntas <span aria-hidden="true" class="arrow">→</span></a>
      </p>
    </div>
  </section>

  <section class="pricing-org" aria-labelledby="pricing-org-title">
    <div class="page-container">
      <div class="pricing-org-inner">
        <p class="eyebrow eyebrow-on-paper">Para organizaciones</p>
        <h2 id="pricing-org-title" class="section-title">
          ¿Inscribes a tu equipo, una cohorte o un departamento?
        </h2>
        <p class="pricing-org-text">
          Muchos de nuestros participantes llegaron a través de su empleador:
          agencias de salud conductual del condado, cuerpos de bomberos,
          escuelas, comunidades de fe, trabajadores de salud comunitaria,
          organizaciones sin fines de lucro. Ofrecemos precios por volumen y
          becas de equidad para grupos. Escribe a Angelica con el número
          aproximado de personas y te responderemos en un día hábil.
        </p>
        <div class="pricing-org-actions">
          <a class="btn-primary" href="mailto:Angelica@emorrisonconsulting.com">
            Escribe a Angelica
          </a>
          <a class="page-hero-link page-hero-link-on-paper" href="/es/faq/">Lee las preguntas frecuentes <span aria-hidden="true" class="arrow">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="page-close">
    <div class="page-container">
      <h2 class="page-close-title">
        Lee el artículo de muestra <span class="title-accent">antes de decidir.</span>
      </h2>
      <p class="page-close-lede">
        Nuestro artículo de muestra, <em>El consejo: por qué (y cómo) lo evitamos</em>,
        te dirá más que cualquier página de precios.
      </p>
      <div class="page-close-actions">
        <a class="btn-primary" href="/es/#sample">Lee el artículo de muestra</a>
        <span class="btn-soon">Inscripción: próximamente</span>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero { background-color: var(--color-navy); background-image: url('/images/topo-light.svg'); background-size: cover; background-position: center; background-repeat: no-repeat; color: var(--color-on-navy); padding: 5rem 0; }
  @media (min-width: 768px) { .page-hero { padding: 7rem 0; } }
  .page-hero-title { font-family: var(--font-serif); font-weight: 400; color: var(--color-on-navy); font-size: clamp(2rem, 4.5vw, 3.75rem); line-height: 1.1; letter-spacing: -0.02em; margin: 0.75rem 0 1.5rem 0; max-width: 22ch; text-wrap: balance; }
  .page-hero-lede { font-family: var(--font-sans); font-size: clamp(1.05rem, 1.4vw, 1.25rem); line-height: 1.6; color: var(--color-on-navy-soft); margin: 0; max-width: 60ch; }
  .page-hero-link { font-family: var(--font-sans); font-size: 0.95rem; font-weight: 500; color: var(--color-on-navy-soft); text-decoration: none; display: inline-flex; align-items: center; gap: 0.4rem; }
  .page-hero-link:hover { color: var(--color-coral); text-decoration: underline; text-underline-offset: 4px; }
  .page-hero-link-on-paper { color: var(--color-blue); }
  .page-hero-link-on-paper:hover { color: var(--color-navy); }

  .eyebrow { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-sans); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-coral-text); margin: 0; }
  .eyebrow-on-dark { color: var(--color-coral); }
  .eyebrow-on-paper { color: var(--color-blue); }
  .title-accent { color: var(--color-coral-deep); }
  .arrow { transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1); display: inline-block; }
  a:hover .arrow { transform: translateX(3px); }

  .section-header { max-width: 60rem; margin-bottom: 3rem; }
  .section-header-center { margin-left: auto; margin-right: auto; text-align: center; }
  .center-prose { margin-left: auto; margin-right: auto; }
  .section-title { font-family: var(--font-serif); font-weight: 400; color: var(--color-navy); font-size: clamp(1.875rem, 3.5vw, 2.75rem); line-height: 1.15; letter-spacing: -0.015em; margin: 0.75rem 0 0 0; text-wrap: balance; }
  .section-lede { margin-top: 1.25rem; font-family: var(--font-sans); font-size: 1.0625rem; line-height: 1.6; color: var(--color-ink-soft); max-width: 60ch; }

  /* Sliding-scale section was removed when pricing simplified to A tu propio
     ritmo and En vivo. Tier-card / pricing-tiers-full / pricing-honor-note
     styles are intentionally omitted. */

  .pricing-compare { padding: 5rem 0; background-color: var(--color-paper-soft); }
  @media (min-width: 768px) { .pricing-compare { padding: 7rem 0; } }
  .format-compare { list-style: none; margin: 0 auto; padding: 0; display: grid; grid-template-columns: 1fr; gap: 1.5rem; max-width: 56rem; }
  @media (min-width: 900px) { .format-compare { grid-template-columns: 1fr 1fr; gap: 2rem; } }
  .format-compare-card { background-color: var(--color-paper); border: 1px solid var(--color-rule); border-radius: 20px; padding: 2rem; display: flex; flex-direction: column; gap: 1.25rem; }
  .format-compare-card-current { background-color: var(--color-navy); color: var(--color-on-navy); border-color: var(--color-navy); }
  .format-compare-head { display: flex; flex-direction: column; gap: 0.5rem; }
  .format-compare-name { font-family: var(--font-serif); font-weight: 500; font-size: 1.5rem; color: var(--color-navy); margin: 0; letter-spacing: -0.01em; }
  .format-compare-card-current .format-compare-name { color: var(--color-on-navy); }
  .format-compare-price { font-family: var(--font-serif); font-weight: 400; font-size: 2.25rem; color: var(--color-coral-deep); line-height: 1; }
  .format-compare-card-current .format-compare-price { color: var(--color-coral); }
  .format-compare-desc { margin: 0; font-family: var(--font-sans); font-size: 0.95rem; line-height: 1.5; color: var(--color-ink-soft); }
  .format-compare-card-current .format-compare-desc { color: var(--color-on-navy-soft); }
  .format-compare-rows { margin: 0; padding: 0; border-top: 1px solid var(--color-rule); }
  .format-compare-card-current .format-compare-rows { border-top-color: oklch(0.97 0.012 70 / 0.15); }
  .format-compare-row { display: grid; grid-template-columns: 1fr auto; gap: 1rem; padding: 0.75rem 0; border-bottom: 1px solid var(--color-rule); font-family: var(--font-sans); font-size: 0.875rem; }
  .format-compare-card-current .format-compare-row { border-bottom-color: oklch(0.97 0.012 70 / 0.15); }
  .format-compare-row dt { color: var(--color-ink-quiet); }
  .format-compare-card-current .format-compare-row dt { color: var(--color-on-navy-quiet); }
  .format-compare-row dd { margin: 0; color: var(--color-navy); font-weight: 500; text-align: right; }
  .format-compare-card-current .format-compare-row dd { color: var(--color-on-navy); }
  .format-compare-cta { align-self: flex-start; }
  .format-compare-here { align-self: flex-start; font-family: var(--font-sans); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-coral); padding: 0.5rem 1rem; border: 1px solid var(--color-coral); border-radius: 9999px; }

  .pricing-faq { padding: 5rem 0; background-color: var(--color-paper); }
  @media (min-width: 768px) { .pricing-faq { padding: 7rem 0; } }
  .pricing-faq-list { list-style: none; margin: 0 auto; padding: 0; max-width: 56rem; }
  .pricing-faq-item { display: grid; grid-template-columns: 1fr; gap: 0.75rem; padding: 2rem 0; border-bottom: 1px solid var(--color-rule); }
  .pricing-faq-item:last-child { border-bottom: 0; }
  @media (min-width: 720px) { .pricing-faq-item { grid-template-columns: 4rem 1fr; gap: 0.75rem 2rem; padding: 2.5rem 0; } }
  .pricing-faq-number { margin: 0; font-family: var(--font-serif); font-weight: 400; font-size: clamp(1.625rem, 2.5vw, 2.25rem); line-height: 1; color: var(--color-coral-deep); }
  .pricing-faq-body { min-width: 0; }
  .pricing-faq-question { margin: 0 0 0.75rem 0; font-family: var(--font-serif); font-weight: 500; font-size: clamp(1.25rem, 1.75vw, 1.5rem); line-height: 1.3; letter-spacing: -0.01em; color: var(--color-navy); text-wrap: balance; }
  .pricing-faq-answer { margin: 0; font-family: var(--font-sans); font-size: 1rem; line-height: 1.7; color: var(--color-ink-soft); max-width: 65ch; }
  .pricing-faq-more { margin: 2.5rem 0 0 0; text-align: center; font-family: var(--font-sans); font-size: 0.95rem; }
  .pricing-faq-more a { color: var(--color-coral-text); text-decoration: none; font-weight: 500; display: inline-flex; align-items: center; gap: 0.4rem; }
  .pricing-faq-more a:hover { color: var(--color-navy); text-decoration: underline; text-underline-offset: 4px; }

  .pricing-org { padding: 5rem 0; background-color: var(--color-paper); }
  @media (min-width: 768px) { .pricing-org { padding: 7rem 0; } }
  .pricing-org-inner { max-width: 56rem; }
  .pricing-org-text { margin: 1.25rem 0 2rem 0; font-family: var(--font-sans); font-size: 1.0625rem; line-height: 1.7; color: var(--color-ink-soft); max-width: 60ch; }
  .pricing-org-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 1.25rem 1.5rem; }

  .page-close { background-color: var(--color-info); padding: 5rem 0; text-align: center; }
  @media (min-width: 768px) { .page-close { padding: 7rem 0; } }
  .page-close-title { font-family: var(--font-serif); font-weight: 500; color: var(--color-navy); font-size: clamp(1.875rem, 3.5vw, 2.75rem); line-height: 1.15; letter-spacing: -0.015em; margin: 0 auto 1rem auto; max-width: 26ch; text-wrap: balance; }
  .page-close-lede { font-family: var(--font-sans); font-size: 1.0625rem; line-height: 1.65; color: var(--color-ink-soft); margin: 0 auto 2rem auto; max-width: 52ch; }
  .page-close-lede em { font-family: var(--font-serif); font-style: italic; font-weight: 500; color: var(--color-navy); }
  .page-close-actions { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 1.25rem 1.5rem; }
</style>
