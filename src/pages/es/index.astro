---
import Layout from "../../layouts/Layout.astro";
import SampleLessonForm from "../../components/SampleLessonForm.astro";

const modules = [
  {
    n: "1",
    title: "Qué es la consejería laica y por qué necesitamos consejeros laicos hoy más que nunca.",
    tease:
      "Cómo los prejuicios y los juicios pueden dañar nuestras relaciones con los demás, y qué podemos hacer para mitigar los nuestros.",
  },
  {
    n: "2",
    title: "Enfoques centrales de consejería",
    tease:
      "Lo que llamamos la «postura base»: las técnicas esenciales que usamos una y otra vez: tono y lenguaje corporal cálidos, preguntas abiertas, reflexión empática, afirmación de fortalezas, y la práctica de contrarrestar la vergüenza. Además, enfoques de consejería basados en fortalezas.",
  },
  {
    n: "3",
    title: "Ayudar a personas con pensamientos que les causan sufrimiento (TCC).",
    tease:
      "Cómo reconocer la ansiedad y la depresión, y estrategias prácticas para ayudar a otras personas que sufren con estas condiciones.",
  },
  {
    n: "4",
    title: "Mantenerse en lo que llamamos «terreno fértil»; asegurarnos de guiar a las personas hacia los temas más útiles que pueden compartir.",
    tease:
      "Usar la psicología positiva para ayudar a otros a fortalecer sus prácticas de felicidad.",
  },
  {
    n: "5",
    title: "Reconocer la adicción y usar la entrevista motivacional para ayudar a las personas a hacer cambios.",
    tease:
      "Cómo ayudar cuando alguien comparte experiencias difíciles de la infancia, y cómo protegernos del trauma vicario.",
  },
  {
    n: "6",
    title: "Cómo preguntar sobre los pensamientos suicidas y qué podemos hacer para ayudar.",
    tease:
      "Humildad cultural y ayudar a otros a comprender sus identidades.",
  },
  {
    n: "7",
    title: "Guía práctica sobre los límites (incluyendo cuándo sí y cuándo no auto-revelarse) para garantizar la seguridad de quienes ayudamos y la nuestra.",
    tease:
      "Cómo terminar una relación de consejería con cuidado, asegurando que quienes ayudamos tengan una despedida saludable con nosotros.",
  },
];

const pressLinks = [
  {
    name: "California Healthline",
    href: "https://californiahealthline.org/news/article/asian-lay-counseling-mental-health-therapist-shortage-oakland-california/",
    title: "Centro de salud asiático prueba un enfoque poco convencional para la consejería",
  },
  {
    name: "STAT News",
    href: "https://www.statnews.com/2024/01/18/mental-health-therapist-shortage-lay-counselors-needed/",
    title: "Ante una escasez nacional de terapeutas, ¿podrían los consejeros laicos cerrar la brecha?",
  },
  {
    name: "el Modesto Bee",
    href: "https://www.modbee.com/news/local/article275363006.html",
    title: "Grave escasez de clínicos de salud mental impulsa al condado de Stanislaus a probar un enfoque audaz",
  },
  {
    name: "el Steinberg Institute",
    href: "https://steinberginstitute.org/champion/elizabeth-morrison-and-alli-moreno/",
    title: "Campeonas Steinberg Institute 2023: Elizabeth Morrison y Alli Moreno",
  },
  {
    name: "Blog de la CHCF",
    href: "https://www.chcf.org/blog/new-workforce-lay-counselors-strives-bridge-mental-health-care-gaps/",
    title: "Una nueva fuerza laboral de consejeros laicos busca cerrar las brechas en salud mental",
  },
];

const courseFormats = [
  {
    n: "01",
    name: "LCA: A tu propio ritmo",
    tease:
      "Nuestro curso totalmente asincrónico, que te brinda habilidades fundamentales de consejería en salud mental según tu propio horario. El curso es profundo y amplio, con información esencial sobre habilidades centrales de consejería para ayudar a quienes enfrentan ansiedad, depresión, problemas de consumo de sustancias y más.",
    href: "#sample",
    cta: "Estás aquí",
    current: true,
  },
  {
    n: "02",
    name: "LCA: En vivo",
    tease:
      "Nuestro curso insignia. Catorce semanas de aprendizaje en vivo, basado en la práctica, con una cohorte de pares. El LCA En Vivo se imparte de forma virtual e incluye 5 sesiones de consejería personal.",
    href: "/contact/",
    cta: "Contáctanos para inscribirte",
    current: false,
  },
  {
    n: "03",
    name: "Certificación de CHW, con énfasis en consejería en salud mental.",
    tease:
      "Certificación de Trabajador de Salud Comunitaria en California, con énfasis en consejería en salud mental. Aprende todas las competencias básicas de CHW más habilidades esenciales de consejería en salud mental.",
    href: "/contact/",
    cta: "Contáctanos para inscribirte",
    current: false,
  },
];

const benefits = [
  "Si trabajas en servicios humanos como Trabajador de Salud Comunitaria, consejero de consumo de sustancias, gestor de casos, navegador de salud o un puesto similar…",
  "Si trabajas en un sistema escolar, eres socorrista de emergencias o líder de fe… haces trabajo de crisis.",
  "Si trabajas en recursos humanos, en sistemas médicos, o eres barbero o estilista…",
  "Si estás sirviendo a personas de tu comunidad que tienen poco o ningún acceso a consejería en salud mental de alta calidad y culturalmente congruente.",
  "Si eres un ayudador de corazón y te apasiona apoyar a los demás.",
  "Si estás ocupado y necesitas un curso flexible que puedas completar a tu propio ritmo, ¡cuando te sea conveniente!",
];

const downloads = [
  {
    title: "Preguntas frecuentes y costos del LCA En Vivo",
    thumb: "/images/pdf-thumb-live-faq.webp",
    href: "https://www.emorrisonconsulting.com/download/lca-faqs-and-costs/?wpdmdl=7827",
    external: true,
  },
  {
    title: "Opciones del curso LCA",
    thumb: "/images/pdf-thumb-course-options.webp",
    href: "/downloads/LCA_Course_Options.pdf",
    external: false,
  },
  {
    title: "Preguntas frecuentes del LCA A tu propio ritmo",
    thumb: "/images/pdf-thumb-self-paced-faq.webp",
    href: "/downloads/LCA_Self_Paced_FAQs.pdf",
    external: false,
  },
  {
    title: "Detalles del LCA A tu propio ritmo",
    thumb: "/images/pdf-thumb-self-paced.webp",
    href: "/downloads/LCA_Self_Paced_QR.pdf",
    external: false,
  },
];
---

<Layout
  lang="es"
  title="Consejería en salud mental, La Academia del Consejero Laico"
  description="Curso de consejería en salud mental a tu propio ritmo para quienes quieren ayudar mejor. Impartido por clínicos titulados y consejeros laicos con experiencia."
  extraSchemas={[{
    "@context": "https://schema.org",
    "@type": "VideoObject",
    name: "La historia de La Academia del Consejero Laico",
    description: "Las co-creadoras Elizabeth Morrison y Alli Moreno comparten la historia y la misión detrás de La Academia del Consejero Laico.",
    thumbnailUrl: "https://img.youtube.com/vi/5c1knT6_ejs/maxresdefault.jpg",
    uploadDate: "2024-01-01T08:00:00-08:00",
    contentUrl: "https://www.youtube.com/watch?v=5c1knT6_ejs",
    embedUrl: "https://www.youtube-nocookie.com/embed/5c1knT6_ejs",
    inLanguage: "en",
    publisher: { "@id": "https://thelaycounseloracademy.com/#organization" },
  }]}
>
  <section class="hero" aria-labelledby="hero-title">
    <div class="page-container">
      <div class="hero-grid">
        <div class="hero-content">
          <p class="hero-kicker">
            <span class="marker-coral" aria-hidden="true"></span>
            Un curso práctico sobre consejería en salud mental.
          </p>

          <h1 id="hero-title" class="hero-title hero-fade">
            Aprende habilidades esenciales de consejería en salud mental.
          </h1>

          <p class="hero-subhead">
            Un curso a tu propio ritmo para todos los que quieren ser mejores
            ayudadores. Impartido por clínicos titulados y consejeros laicos con
            amplia experiencia.
          </p>

          <div class="hero-actions">
            <a class="btn-primary" href="#sample">
              Lee el artículo de muestra
            </a>
            <span class="hero-enroll-soon">
              Inscripción al curso: <strong>próximamente</strong>
            </span>
          </div>

          <p class="hero-cta-note">
            Es <em>El consejo: por qué (y cómo) lo evitamos</em>, del Módulo 2
            del curso.
          </p>
        </div>

        <figure class="hero-photo">
          <img
            src="/images/hero-counseling-2.webp"
            alt="Una consejera laica hablando y gesticulando con la mano sobre el corazón durante una sesión"
            width="537"
            height="557"
            class="hero-photo-img"
            loading="eager"
            fetchpriority="high"
          />
        </figure>
      </div>

      <div class="hero-trust-panel" aria-label="Aparición en">
        <span class="hero-trust-panel-label">Aparición en</span>
        <div class="hero-trust-panel-logos">
          <img src="/images/press/chcf-on-navy.png" alt="California Health Care Foundation" width="880" height="120" class="hero-trust-logo hero-trust-logo-chcf" loading="eager" />
          <img src="/images/press/stat-on-navy.svg" alt="STAT News" width="516" height="100" class="hero-trust-logo hero-trust-logo-stat" loading="eager" />
          <span class="hero-trust-logo hero-trust-logo-modbee" aria-label="The Modesto Bee">The Modesto Bee</span>
          <img src="/images/press/steinberg-on-navy.png" alt="Steinberg Institute" width="721" height="157" class="hero-trust-logo hero-trust-logo-steinberg" loading="eager" />
          <img src="/images/press/healthline-on-navy.svg" alt="California Healthline" width="443" height="53" class="hero-trust-logo hero-trust-logo-healthline" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <section class="framing reveal" aria-label="Para quién es este programa">
    <div class="page-container">
      <div class="framing-grid">
        <div class="framing-prose">
          <p class="framing-text">
            Probablemente eres la persona en tu familia, comunidad o grupo de
            amigos a la que la gente recurre cuando necesita apoyo; seguramente
            te han dicho que es fácil hablar contigo. ¡Esto significa que eres
            un oyente empático y hábil! Este curso desarrollará las habilidades
            que ya tienes, profundizará tu comprensión de las condiciones de
            salud mental, y te dará habilidades prácticas de consejería para
            ayudar a los demás aún más.
          </p>
          <p class="framing-aside">
            Conviértete en el mejor ayudador que puedas ser, en un momento en
            que el mundo más te necesita.
          </p>
        </div>
        <figure class="framing-photo">
          <img
            src="/images/hero-counseling-900.webp"
            alt="Una cohorte de graduados de la Academia del Consejero Laico al finalizar su formación"
            width="900"
            height="329"
            class="framing-photo-img"
            loading="lazy"
          />
          <figcaption class="framing-photo-caption">
            ¡Día de graduación en uno de nuestros cursos presenciales!
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="lay-counselor reveal" aria-labelledby="lay-counselor-title">
    <div class="page-container">
      <div class="lay-counselor-grid">
        <figure class="lay-counselor-photo">
          <img
            src="/images/what-is-lay-counselor.webp"
            alt="Una trabajadora de salud comunitaria en un momento de conversación"
            width="540"
            height="600"
            loading="lazy"
          />
        </figure>
        <div class="lay-counselor-body">
          <p class="eyebrow eyebrow-on-paper">Lenguaje claro</p>
          <h2 id="lay-counselor-title" class="section-title">
            ¿Qué es la <span class="title-accent">consejería laica?</span>
          </h2>
          <p class="lay-counselor-text">
            La consejería laica es consejería en salud mental, ofrecida por
            ayudadores que han aprendido las habilidades fuera de las vías
            académicas y de licenciatura convencionales. Se sientan con la gente
            en momentos difíciles y ofrecen cuidado empático y basado en
            evidencia, llenando vacíos que los clínicos titulados por sí solos
            no pueden cubrir.
          </p>
          <a class="link-arrow" href="https://www.emorrisonconsulting.com/what-is-a-lay-counselor/" rel="noopener">
            Más información
            <span aria-hidden="true" class="arrow">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="formats" class="formats reveal" aria-labelledby="formats-title">
    <div class="page-container">
      <header class="section-header section-header-center">
        <p class="eyebrow">Cursos y certificaciones</p>
        <h2 id="formats-title" class="section-title">
          ¿Qué es la <span class="title-accent">Academia del Consejero Laico?</span>
        </h2>
        <p class="section-lede center-prose">
          La LCA es un curso que te equipa con habilidades prácticas en
          consejería en salud mental.
        </p>
      </header>

      <ol class="format-grid" aria-label="Formatos del curso">
        {courseFormats.map((fmt) => (
          <li class={`format-card ${fmt.current ? "is-current" : ""}`}>
            <span class="format-number" aria-hidden="true">{fmt.n}</span>
            <h3 class="format-name">{fmt.name}</h3>
            <p class="format-tease">{fmt.tease}</p>
            {fmt.current ? (
              <span class="format-current-badge">Estás aquí</span>
            ) : (
              <a class="format-link" href={fmt.href} {...(fmt.href.startsWith("http") ? { rel: "noopener" } : {})}>
                {fmt.cta}
                <span aria-hidden="true" class="arrow">→</span>
              </a>
            )}
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="video reveal" aria-labelledby="video-title">
    <div class="page-container">
      <div class="video-wrap">
        <iframe
          src="https://www.youtube-nocookie.com/embed/5c1knT6_ejs?rel=0"
          title="Las cocreadoras Elizabeth Morrison y Alli Moreno comparten la historia de La Academia del Consejero Laico"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          referrerpolicy="strict-origin-when-cross-origin"
        ></iframe>
      </div>
      <h2 id="video-title" class="video-caption">
        Escucha a las cocreadoras <span class="title-accent">Elizabeth Morrison y Alli Moreno</span> contar la historia y la misión detrás de La Academia del Consejero Laico.
      </h2>
    </div>
  </section>

  <section id="teachers" class="teachers reveal" aria-labelledby="teachers-title">
    <div class="page-container">
      <header class="section-header">
        <p class="eyebrow">Profesorado</p>
        <h2 id="teachers-title" class="section-title">
          Las co-creadoras y el profesorado.
        </h2>
        <p class="section-lede">
          La academia es pequeña a propósito. Aprendes de personas que aún
          hacen el trabajo, no de una plataforma sin rostro.
        </p>
      </header>

      <div class="teacher-spread">
        <article class="teacher">
          <img
            src="/images/elizabeth-headshot.webp"
            alt="Fotografía de Elizabeth Morrison"
            width="320"
            height="320"
            class="teacher-photo"
            loading="lazy"
          />
          <div class="teacher-body">
            <h3 class="teacher-name">Elizabeth Morrison</h3>
            <p class="teacher-credential">PhD, LCSW, MAC. Co-creadora de la LCA y clínica titulada.</p>
            <p class="teacher-bio">
              Elizabeth tiene un Doctorado en Psicología, es Trabajadora Social
              Clínica Titulada, y tiene una Maestría en Consejería de
              Adicciones. Ha ejercido como terapeuta durante más de 30 años,
              trabajando en entornos de tratamiento de adicciones, sistemas de
              atención primaria y clínicas de atención especializada. Le apasiona
              ampliar el acceso a la atención de salud mental capacitando a
              miembros de confianza de la comunidad para que brinden consejería
              en salud mental.
            </p>
            <a class="teacher-link" href="/teachers/elizabeth-morrison/">
              Lee más sobre Elizabeth
              <span aria-hidden="true" class="arrow">→</span>
            </a>
          </div>
        </article>

        <article class="teacher">
          <img
            src="/images/alli-moreno-headshot.webp"
            alt="Fotografía de Alli Moreno"
            width="360"
            height="360"
            class="teacher-photo"
            loading="lazy"
          />
          <div class="teacher-body">
            <h3 class="teacher-name">Alli Moreno</h3>
            <p class="teacher-credential">Alli es la Co-creadora de la LCA y Consejera Laica.</p>
            <p class="teacher-bio">
              Alli cocreó La Academia del Consejero Laico junto con Elizabeth.
              Como la mayoría de los consejeros laicos, Alli tenía una habilidad
              natural y la fortaleció con más formación, aprendizaje continuo y
              práctica. Le apasiona elevar y apoyar a los miembros de la
              comunidad que ya brindan apoyo de salud mental a las personas a las
              que sirven.
            </p>
            <a class="teacher-link" href="/teachers/alli-moreno/">
              Lee más sobre Alli
              <span aria-hidden="true" class="arrow">→</span>
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="benefits reveal" aria-labelledby="benefits-title">
    <div class="page-container">
      <header class="section-header section-header-center">
        <p class="eyebrow">Para quién es</p>
        <h2 id="benefits-title" class="section-title">
          ¿Es la Academia del Consejero Laico <span class="title-accent">para mí?</span>
        </h2>
        <p class="section-lede center-prose">
          ¿Hablas a menudo con personas que comparten contigo sus dificultades
          de salud mental? ¡Entonces la respuesta es sí!
        </p>
      </header>

      <ul class="benefits-grid" aria-label="¿Es esto para mí?">
        {benefits.map((b) => (
          <li class="benefit-item">
            <span class="benefit-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="32" height="32">
                <circle cx="16" cy="16" r="16" fill="var(--color-blue)"/>
                <path d="M22.4 9.9c-0.6-0.3-1.3 0.3-1.7 0.7-1 1-1.8 2-2.7 3-1 1.1-1.9 2.1-3 3.2-0.6 0.6-1.2 1.2-1.6 1.9-0.9-0.9-1.6-1.8-2.6-2.5-0.7-0.5-1.9-0.9-1.9 0.4 0 1.7 1.5 3.5 2.6 4.6 0.5 0.5 1.1 1 1.8 1 0.9 0 1.7-1 2.2-1.6 0.9-1 1.7-2 2.5-3 1.1-1.3 2.2-2.6 3.2-4 0.7-0.8 2.7-2.8 1.2-3.7z" fill="#fff"/>
              </svg>
            </span>
            <p class="benefit-text">{b}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="testimonial reveal" aria-label="La experiencia de una graduada">
    <div class="page-container">
      <figure class="testimonial-block">
        <blockquote class="testimonial-quote">
          Sin duda el curso más valioso que he tomado. Uso las habilidades de
          consejería en salud mental que aprendí en la LCA todos los días, con
          mis pacientes pero también en casa.
        </blockquote>
        <figcaption class="testimonial-attribution">
          <span class="marker-coral" aria-hidden="true"></span>
          Oscar, Trabajador de Salud Comunitaria y egresado de la LCA.
        </figcaption>
      </figure>
    </div>
  </section>

  <section id="program" class="program reveal" aria-labelledby="program-title">
    <div class="page-container">
      <header class="section-header">
        <p class="eyebrow">El currículum</p>
        <h2 id="program-title" class="section-title">
          Siete módulos. Catorce sesiones. Setenta horas de habilidades
          prácticas de consejería en salud mental.
        </h2>
        <p class="section-lede">
          La Academia del Consejero Laico A tu propio ritmo es totalmente
          asincrónica. Lees artículos, ves videos, escuchas audio, y escribes
          reflexiones y completas verificaciones de aprendizaje según tu propio
          horario.
        </p>
      </header>

      <ol class="program-grid" aria-label="Módulos del curso">
        {modules.map((mod) => (
          <li class="program-card">
            <span class="program-number" aria-hidden="true">{mod.n.padStart(2, "0")}</span>
            <p class="program-eyebrow">Módulo {mod.n}</p>
            <h3 class="program-title">{mod.title}</h3>
            <p class="program-tease">{mod.tease}</p>
            <a class="program-link" href={`/curriculum#module-${mod.n}`}>
              Lee el módulo
              <span aria-hidden="true" class="arrow">→</span>
            </a>
          </li>
        ))}
      </ol>

      <p class="program-foot">
        Los objetivos completos de cada módulo y el detalle por sesión están en
        la <a href="/curriculum/">página del currículum</a>.
      </p>
    </div>
  </section>

  <section class="inside reveal" aria-labelledby="inside-title">
    <div class="page-container">
      <header class="section-header section-header-center">
        <p class="eyebrow">Lo que realmente recibes</p>
        <h2 id="inside-title" class="section-title">
          Dentro del <span class="title-accent">curso a tu propio ritmo.</span>
        </h2>
        <p class="section-lede center-prose">
          Por $1,200 recibirás el curso completo de 70 horas de La Academia del
          Consejero Laico, a tu propio ritmo.
        </p>
      </header>

      <ul class="inside-grid" aria-label="Lo que incluye el curso">
        <li class="inside-item">
          <span class="inside-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
          </span>
          <div class="inside-body">
            <h3 class="inside-name">El curso es tuyo de por vida, para volver a él una y otra vez.</h3>
            <p class="inside-text">Siete módulos y catorce sesiones. Avanza tan rápido o tan lento como necesites.</p>
          </div>
        </li>

        <li class="inside-item">
          <span class="inside-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 18v-6a9 9 0 0 1 18 0v6"/>
              <path d="M21 19a2 2 0 0 1-2 2h-1v-7h3z"/>
              <path d="M3 19a2 2 0 0 0 2 2h1v-7H3z"/>
            </svg>
          </span>
          <div class="inside-body">
            <h3 class="inside-name">Aprendizaje multimodal: leer, escuchar, mirar y escribir.</h3>
