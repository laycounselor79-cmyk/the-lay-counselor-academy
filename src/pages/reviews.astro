---
import Layout from "../layouts/Layout.astro";

const pressLinks = [
  {
    name: "California Healthline",
    title: "Asian Health Center Tries Unconventional Approach to Counseling",
    href: "https://californiahealthline.org/news/article/asian-lay-counseling-mental-health-therapist-shortage-oakland-california/",
  },
  {
    name: "STAT News",
    title: "Amid a dire nationwide therapist shortage, could lay counselors help close the gap?",
    href: "https://www.statnews.com/2024/01/18/mental-health-therapist-shortage-lay-counselors-needed/",
  },
  {
    name: "the Modesto Bee",
    title: "Severe shortage of mental health clinicians prompts Stanislaus County to try bold approach",
    href: "https://www.modbee.com/news/local/article275363006.html",
  },
  {
    name: "the Steinberg Institute",
    title: "2023 Steinberg Institute Champions: Elizabeth Morrison & Alli Moreno",
    href: "https://steinberginstitute.org/champion/elizabeth-morrison-and-alli-moreno/",
  },
  {
    name: "CHCF Blog",
    title: "New Workforce of Lay Counselors Strives to Bridge Mental Health Care Gaps",
    href: "https://www.chcf.org/blog/new-workforce-lay-counselors-strives-bridge-mental-health-care-gaps/",
  },
];
---

<Layout
  title="Reviews and endorsements, The Lay Counselor Academy"
  description="Press coverage, the CHCF external evaluation, and feedback from over twelve hundred graduates of The Lay Counselor Academy."
  extraSchemas={pressLinks.map((p) => ({
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    headline: p.title,
    url: p.href,
    about: { "@id": "https://thelaycounseloracademy.com/#organization" },
    publisher: { "@type": "Organization", name: p.name },
  })).concat([{
    "@context": "https://schema.org",
    "@type": "Report",
    name: "Lay Counselor Academy Evaluation: Strengthening the Behavioral Health Workforce",
    url: "https://www.chcf.org/publication/lay-counselor-academy-evaluation-strengthening-behavioral-health-workforce/",
    datePublished: "2025",
    about: { "@id": "https://thelaycounseloracademy.com/#organization" },
    publisher: { "@type": "Organization", name: "California Health Care Foundation" },
  }])}
>
  <section class="page-hero">
    <div class="page-container">
      <p class="eyebrow eyebrow-on-dark">Outside voices</p>
      <h1 class="page-hero-title">
        What people say about <span class="title-accent">the work.</span>
      </h1>
      <p class="page-hero-lede">
        The strongest reviews of the academy come from the people who have done
        it. The most credible is the California Health Care Foundation's
        independent evaluation. Both are here.
      </p>
    </div>
  </section>

  <section class="featured-quote">
    <div class="page-container">
      <figure class="quote-block">
        <blockquote class="quote-text">
          Hands down the most valuable course I've ever taken. I use the mental
          health counseling skills I learned in the LCA every day, with my
          patients but also at home.
        </blockquote>
        <figcaption class="quote-attribution">
          <span class="marker-coral" aria-hidden="true"></span>
          Oscar, LCA participant.
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="chcf-block">
    <div class="page-container">
      <div class="chcf-grid">
        <div class="chcf-cover">
          <img
            src="/images/chcf-evaluation.webp"
            alt="Cover of the California Health Care Foundation 2025 evaluation report of The Lay Counselor Academy"
            width="240"
            height="312"
            loading="lazy"
          />
        </div>
        <div class="chcf-body">
          <p class="eyebrow eyebrow-on-dark">An external evaluation</p>
          <h2 class="chcf-title">
            The California Health Care Foundation evaluated the academy in 2025.
          </h2>
          <p class="chcf-text">
            Their report concluded that lay counselor training, done seriously,
            can meaningfully expand the mental health workforce in communities
            where licensed clinicians are scarce. It also examined how
            graduates use the material in their working lives.
          </p>
          <p class="chcf-text">
            We think it's the most honest outside look at this academy.
            We would rather you read it than take our word for any of this.
          </p>
          <a
            class="btn-on-dark"
            href="https://www.chcf.org/publication/lay-counselor-academy-evaluation-strengthening-behavioral-health-workforce/"
            rel="noopener"
          >
            Read the evaluation
            <span aria-hidden="true" class="arrow">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="press-on-page">
    <div class="page-container">
      <header class="section-header section-header-center">
        <p class="eyebrow">In the press</p>
        <h2 class="section-title">
          Five pieces of <span class="title-accent">independent coverage.</span>
        </h2>
      </header>
      <ul class="press-articles-list">
        {pressLinks.map((p) => (
          <li>
            <a href={p.href} rel="noopener" target="_blank" class="press-articles-link">
              <span class="press-articles-publication">{p.name}</span>
              <span class="press-articles-title">{p.title}</span>
              <span aria-hidden="true" class="arrow press-articles-arrow">↗</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="reviews-more">
    <div class="page-container">
      <h2 class="reviews-more-title">More graduate stories, on the way.</h2>
      <p class="reviews-more-text">
        Over twelve hundred people have come through the academy since 2021.
        We are gathering their stories and adding them here. If you are a
        graduate and would like to share, write to Angelica.
      </p>
      <a class="btn-secondary" href="mailto:Angelica@emorrisonconsulting.com?subject=Sharing%20my%20LCA%20story">
        Share your story
        <span aria-hidden="true" class="arrow">→</span>
      </a>
    </div>
  </section>
</Layout>

<style>
  .page-hero { background-color: var(--color-navy); background-image: url('/images/topo-light.svg'); background-size: cover; background-position: center; background-repeat: no-repeat; color: var(--color-on-navy); padding: 5rem 0; }
  @media (min-width: 768px) { .page-hero { padding: 7rem 0; } }
  .page-hero-title { font-family: var(--font-serif); font-weight: 400; color: var(--color-on-navy); font-size: clamp(2rem, 4.5vw, 3.75rem); line-height: 1.1; letter-spacing: -0.02em; margin: 0.75rem 0 1.5rem 0; max-width: 22ch; text-wrap: balance; }
  .page-hero-lede { font-family: var(--font-sans); font-size: clamp(1.05rem, 1.4vw, 1.25rem); line-height: 1.6; color: var(--color-on-navy-soft); margin: 0; max-width: 60ch; }
  .eyebrow { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-sans); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-coral-text); margin: 0; }
  .eyebrow-on-dark { color: var(--color-coral); }
  .title-accent { color: var(--color-coral-deep); }
  .section-header { max-width: 60rem; margin-bottom: 3rem; }
  .section-header-center { margin-left: auto; margin-right: auto; text-align: center; }
  .section-title { font-family: var(--font-serif); font-weight: 400; color: var(--color-navy); font-size: clamp(1.875rem, 3.5vw, 2.75rem); line-height: 1.15; letter-spacing: -0.015em; margin: 0.75rem 0 0 0; text-wrap: balance; }
  .arrow { transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1); display: inline-block; }
  a:hover .arrow { transform: translateX(3px); }

  .featured-quote { padding: 5rem 0; background-color: var(--color-paper); text-align: center; }
  @media (min-width: 768px) { .featured-quote { padding: 7rem 0; } }
  .quote-block { max-width: 52rem; margin: 0 auto; }
  .quote-text { margin: 0; font-family: var(--font-serif); font-weight: 500; font-size: clamp(1.5rem, 3vw, 2.25rem); line-height: 1.35; color: var(--color-navy); letter-spacing: -0.015em; text-wrap: pretty; }
  .quote-text::before { content: "\201C"; }
  .quote-text::after { content: "\201D"; }
  .quote-attribution { margin: 1.5rem 0 0 0; font-family: var(--font-sans); font-size: 0.95rem; color: var(--color-ink-quiet); display: inline-flex; align-items: center; gap: 0.625rem; }

  .chcf-block { padding: 5rem 0; background-color: var(--color-navy); color: var(--color-on-navy); }
  @media (min-width: 768px) { .chcf-block { padding: 7rem 0; } }
  .chcf-grid { display: grid; grid-template-columns: 1fr; gap: 2.5rem; align-items: start; }
  @media (min-width: 720px) { .chcf-grid { grid-template-columns: 200px 1fr; gap: 3.5rem; } }
  @media (min-width: 1024px) { .chcf-grid { grid-template-columns: 240px 1fr; gap: 5rem; } }
  .chcf-cover img { width: 100%; max-width: 240px; height: auto; border-radius: 4px; box-shadow: 0 2px 4px oklch(0 0 0 / 0.25), 0 16px 40px oklch(0 0 0 / 0.35); }
  .chcf-title { font-family: var(--font-serif); font-weight: 400; color: var(--color-on-navy); font-size: clamp(1.875rem, 3.5vw, 2.75rem); line-height: 1.15; letter-spacing: -0.015em; margin: 0.5rem 0 1.25rem 0; text-wrap: balance; max-width: 22ch; }
  .chcf-text { margin: 0 0 1rem 0; font-family: var(--font-sans); font-size: 1.05rem; line-height: 1.65; color: var(--color-on-navy-soft); max-width: 56ch; }
  .chcf-text + .chcf-text { margin-top: 0.75rem; }
  .chcf-body .btn-on-dark { margin-top: 1.5rem; }

  .press-on-page { padding: 5rem 0; background-color: var(--color-paper); }
  @media (min-width: 768px) { .press-on-page { padding: 7rem 0; } }
  .press-articles-list { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--color-rule); max-width: 56rem; margin-left: auto; margin-right: auto; }
  .press-articles-list li { border-bottom: 1px solid var(--color-rule); }
  .press-articles-link { display: grid; grid-template-columns: 1fr auto; grid-template-rows: auto auto; column-gap: 1rem; row-gap: 0.25rem; padding: 1.25rem 0; text-decoration: none; color: var(--color-navy); transition: color 200ms cubic-bezier(0.22, 1, 0.36, 1); }
  .press-articles-link:hover { color: var(--color-coral-deep); }
  .press-articles-link:hover .press-articles-title { text-decoration: underline; text-underline-offset: 3px; }
  .press-articles-publication { grid-column: 1; grid-row: 1; font-family: var(--font-sans); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-coral-deep); }
  .press-articles-title { grid-column: 1; grid-row: 2; font-family: var(--font-serif); font-weight: 500; font-size: clamp(1.1rem, 1.5vw, 1.375rem); line-height: 1.3; letter-spacing: -0.01em; }
  .press-articles-arrow { grid-column: 2; grid-row: 1 / span 2; align-self: center; font-size: 1.5rem; color: var(--color-ink-quiet); }

  .reviews-more { padding: 5rem 0; background-color: var(--color-paper-soft); }
  @media (min-width: 768px) { .reviews-more { padding: 7rem 0; } }
  .reviews-more-title { font-family: var(--font-serif); font-weight: 500; color: var(--color-navy); font-size: clamp(1.5rem, 2.5vw, 2rem); line-height: 1.2; letter-spacing: -0.01em; margin: 0 0 1rem 0; }
  .reviews-more-text { margin: 0 0 2rem 0; font-family: var(--font-sans); font-size: 1.0625rem; line-height: 1.7; color: var(--color-ink-soft); max-width: 60ch; }
</style>
