---
import "@fontsource/lora/400.css";
import "@fontsource/lora/500.css";
import "@fontsource/lora/400-italic.css";
import "@fontsource/poppins/400.css";
import "@fontsource/poppins/500.css";
import "@fontsource/poppins/600.css";
import "../styles/global.css";

import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Analytics from "../components/Analytics.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  lang?: "en" | "es";
  extraSchemas?: Record<string, unknown>[];
  breadcrumbName?: string;
}

const {
  title = "The Lay Counselor Academy, A how-to course on mental health counseling",
  description = "A 70-hour self-paced course teaching mental health counseling to lay counselors, volunteers, and non-clinicians. By Elizabeth Morrison, PhD.",
  canonical,
  ogImage,
  lang = "en",
  extraSchemas = [],
} = Astro.props;

const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).toString();

/* Routes that have authored Spanish translations under src/pages/es/. Any
 * other route falls back to the English version via Astro's i18n fallback,
 * which writes a noindex redirect stub at /es/<path>/. We must NOT emit a
 * hreflang="es" link for those, pointing Google at a noindex stub breaks
 * the reciprocity rule and the hreflang annotation gets flagged as broken. */
const pathsWithSpanish = new Set([
  "/",
  "/contact/",
  "/curriculum/",
  "/faq/",
  "/pricing/",
  "/reviews/",
]);

/* hreflang alternates: only emit ES when a real Spanish file exists for this
 * route. EN + x-default always emit (every page is canonically English). */
function getAlternates(pathname: string): { enPath: string; esPath: string | null } {
  const clean = pathname.replace(/\/$/, "") || "/";
  let pathNoLocale: string;
  if (clean === "/" || clean === "/es") {
    pathNoLocale = "/";
  } else if (clean.startsWith("/es/")) {
    pathNoLocale = clean.slice(3);
  } else {
    pathNoLocale = clean;
  }
  const enPath = pathNoLocale === "/" ? "/" : pathNoLocale + "/";
  const esPath = pathsWithSpanish.has(enPath)
    ? (enPath === "/" ? "/es/" : "/es" + enPath)
    : null;
  return { enPath, esPath };
}

const { enPath, esPath } = getAlternates(Astro.url.pathname);
const enAbsoluteUrl = new URL(enPath, Astro.site).toString();
const esAbsoluteUrl = esPath ? new URL(esPath, Astro.site).toString() : null;

/* BreadcrumbList: auto-generated from the canonical pathname. Every page
 * gets Home + (optional intermediate) + current page. Inner pages explicitly
 * pass a label via the Layout `breadcrumbName` prop; if missing we derive
 * from the page title. */
const breadcrumbName = (Astro.props as { breadcrumbName?: string }).breadcrumbName;
function buildBreadcrumb(pathname: string, current: string): Record<string, unknown> | null {
  const clean = pathname.replace(/\/$/, "") || "/";
  if (clean === "/" || clean === "/es") return null;
  const inEs = clean.startsWith("/es/");
  const homeLabel = inEs ? "Inicio" : "Home";
  const homeUrl = inEs ? "https://thelaycounseloracademy.com/es/" : "https://thelaycounseloracademy.com/";
  const items: { name: string; item: string }[] = [
    { name: homeLabel, item: homeUrl },
  ];
  /* Handle two-deep paths like /teachers/elizabeth-morrison/ by injecting
   * a "Teachers" parent if one exists. We don't have a /teachers/ index, so
   * skip the intermediate for that case (just home → person). */
  items.push({ name: current, item: new URL(clean + "/", "https://thelaycounseloracademy.com").toString() });
  return {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: items.map((entry, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: entry.name,
      item: entry.item,
    })),
  };
}
const derivedBreadcrumbName = breadcrumbName ?? title.split(",")[0]?.trim() ?? "";
const breadcrumbSchema = derivedBreadcrumbName
  ? buildBreadcrumb(Astro.url.pathname, derivedBreadcrumbName)
  : null;

/* Lang-aware text for schema fields. The Organization and Course entities
 * keep the same @id across languages so search engines treat them as one
 * entity with multilingual surface forms. Each page's JSON-LD renders the
 * name/description in the matching language. */
const t = lang === "es"
  ? {
      brandName: "La Academia del Consejero Laico",
      brandAlternateNames: [
        "LCA",
        "The Lay Counselor Academy",
        "La Academia del Consejero Laico: A tu propio ritmo",
      ],
      orgDescription:
        "Un programa de formación no académica en consejería de salud mental para consejeros laicos, padrinos, voluntarios de escucha y otros no-clínicos.",
      founderJobTitle:
        "Fundadora y co-creadora, La Academia del Consejero Laico",
      memberJobTitle: "Co-creadora, La Academia del Consejero Laico",
      parentOrgName: "Elizabeth Morrison Consulting",
      courseName: "La Academia del Consejero Laico: A tu propio ritmo",
      courseAlternateName: "The Lay Counselor Academy: Self-Paced",
      courseDescription:
        "Un curso de 70 horas a tu propio ritmo que enseña habilidades esenciales de consejería en salud mental a no-clínicos.",
      credential: "Certificado de finalización",
      prerequisites: "Ninguno, diseñado para no-clínicos y consejeros laicos.",
      creditsValue: "70 horas",
      audienceRole:
        "Consejero laico, voluntario de escucha, trabajador de salud comunitaria, ayudante no-clínico",
      areaServedName: "Todo el mundo (en línea)",
    }
  : {
      brandName: "The Lay Counselor Academy",
      brandAlternateNames: [
        "LCA",
        "La Academia del Consejero Laico",
        "The Lay Counselor Academy: Self-Paced",
      ],
      orgDescription:
        "A non-academic training program in mental health counseling for lay counselors, sponsors, volunteer listeners, and other non-clinicians.",
      founderJobTitle: "Founder and Co-Creator, The Lay Counselor Academy",
      memberJobTitle: "Co-Creator, The Lay Counselor Academy",
      parentOrgName: "Elizabeth Morrison Consulting",
      courseName: "The Lay Counselor Academy: Self-Paced",
      courseAlternateName: "La Academia del Consejero Laico: A tu propio ritmo",
      courseDescription:
        "A 70-hour self-paced course teaching essential mental health counseling skills to non-clinicians.",
      credential: "Certificate of Completion",
      prerequisites: "None, designed for non-clinicians and lay counselors.",
      creditsValue: "70 hours",
      audienceRole:
        "Lay counselor, volunteer listener, community health worker, non-clinician helper",
      areaServedName: "Worldwide (online)",
    };

/* Resolve the per-page OG card. Each entry under /public/og/ is a 1200×630
 * social-share image generated by scripts/generate-og.py, see that file
 * for the source-of-truth content. Layout.astro derives the path from the
 * current pathname so individual pages do not need to opt in. */
function resolveOgImage(pathname: string): string {
  const clean = pathname.replace(/\/$/, "") || "/";
  const map: Record<string, string> = {
    "/": "/og/home.png",
    "/curriculum": "/og/curriculum.png",
    "/pricing": "/og/pricing.png",
    "/faq": "/og/faq.png",
    "/contact": "/og/contact.png",
    "/reviews": "/og/reviews.png",
    "/teachers/elizabeth-morrison": "/og/teachers-elizabeth-morrison.png",
    "/teachers/alli-moreno": "/og/teachers-alli-moreno.png",
    "/es": "/og/es-home.png",
  };
  return map[clean] ?? "/og/home.png";
}

const resolvedOgImage = ogImage ?? resolveOgImage(Astro.url.pathname);

/* Same-as schema links the LCA brand to its parent (Elizabeth Morrison
 * Consulting) and to the social profiles it shares with the parent. As
 * LCA-specific socials are created, add them here. The point of sameAs is
 * to give AI a verifiable map of "this entity, in these other places." */
const lcaSameAs = [
  "https://www.emorrisonconsulting.com",
  "https://www.emorrisonconsulting.com/services/lay-counselor-training-academy/",
  "https://www.linkedin.com/in/elizabeth-morrison-consulting/",
  "https://www.youtube.com/channel/UC9AfJJrLIpeZl0Liigh1UDA",
  "https://www.instagram.com/emorrisonconsulting/",
];

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "@id": "https://thelaycounseloracademy.com/#organization",
  name: t.brandName,
  alternateName: t.brandAlternateNames,
  url: "https://thelaycounseloracademy.com",
  logo: "https://thelaycounseloracademy.com/images/lca-logo.png",
  description: t.orgDescription,
  inLanguage: [lang, lang === "en" ? "es" : "en"],
  sameAs: lcaSameAs,
  parentOrganization: {
    "@type": "Organization",
    name: t.parentOrgName,
    url: "https://www.emorrisonconsulting.com",
    sameAs: "https://www.emorrisonconsulting.com",
  },
  address: {
    "@type": "PostalAddress",
    addressRegion: "CA",
    addressCountry: "US",
  },
  contactPoint: {
    "@type": "ContactPoint",
    email: "Angelica@emorrisonconsulting.com",
    contactType: lang === "es" ? "atención al cliente" : "customer support",
    availableLanguage: ["English", "Spanish"],
  },
  founder: {
    "@type": "Person",
    "@id": "https://thelaycounseloracademy.com/#person-elizabeth-morrison",
    name: "Elizabeth Morrison",
    honorificSuffix: "PhD, LCSW, MAC",
    jobTitle: t.founderJobTitle,
    url: "https://thelaycounseloracademy.com/teachers/elizabeth-morrison/",
    image: {
      "@type": "ImageObject",
      url: "https://thelaycounseloracademy.com/images/elizabeth-headshot.webp",
      width: 411,
      height: 411,
    },
    sameAs: [
      "https://www.linkedin.com/in/elizabeth-morrison-consulting/",
      "https://www.emorrisonconsulting.com",
    ],
  },
  member: [
    {
      "@type": "Person",
      "@id": "https://thelaycounseloracademy.com/#person-alli-moreno",
      name: "Alli Moreno",
      jobTitle: t.memberJobTitle,
      url: "https://thelaycounseloracademy.com/teachers/alli-moreno/",
      image: {
        "@type": "ImageObject",
        url: "https://thelaycounseloracademy.com/images/alli-moreno-headshot.webp",
        width: 400,
        height: 400,
      },
    },
  ],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://thelaycounseloracademy.com/#website",
  name: t.brandName,
  alternateName: t.brandAlternateNames,
  url: "https://thelaycounseloracademy.com",
  publisher: { "@id": "https://thelaycounseloracademy.com/#organization" },
  inLanguage: ["en", "es"],
};

const webpageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": canonicalUrl + "#webpage",
  url: canonicalUrl,
  name: title,
  description: description,
  isPartOf: { "@id": "https://thelaycounseloracademy.com/#website" },
  about: { "@id": "https://thelaycounseloracademy.com/#course" },
  inLanguage: lang,
};

const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "@id": "https://thelaycounseloracademy.com/#course",
  name: t.courseName,
  alternateName: t.courseAlternateName,
  description: t.courseDescription,
  inLanguage: lang,
  url: lang === "es" ? "https://thelaycounseloracademy.com/es/" : "https://thelaycounseloracademy.com/",
  image: lang === "es"
    ? "https://thelaycounseloracademy.com/og/es-home.png"
    : "https://thelaycounseloracademy.com/og/home.png",
  provider: {
    "@id": "https://thelaycounseloracademy.com/#organization",
  },
  educationalCredentialAwarded: t.credential,
  coursePrerequisites: t.prerequisites,
  numberOfCredits: { "@type": "StructuredValue", value: t.creditsValue },
  audience: {
    "@type": "EducationalAudience",
    educationalRole: t.audienceRole,
  },
  hasCourseInstance: {
    "@type": "CourseInstance",
    courseMode: "online",
    courseWorkload: "PT70H",
    inLanguage: lang,
  },
  offers: {
    "@type": "Offer",
    price: "1200",
    priceCurrency: "USD",
    category: "Paid",
    availability: lang === "es" ? "https://schema.org/PreOrder" : "https://schema.org/InStock",
    url: lang === "es" ? undefined : "https://app.teachfloor.com/the-lay-counselor-academy/c/32305",
    seller: { "@id": "https://thelaycounseloracademy.com/#organization" },
    validFrom: "2024-09-01",
    priceValidUntil: "2026-12-31",
    areaServed: {
      "@type": "Place",
      name: t.areaServedName,
    },
  },
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <Analytics />
    <meta name="color-scheme" content="light" />
    {/* LIVE: client greenlit going public on 2026-07-02 (Amanda's "ready to
        move forward and launch" email). Site is indexed. */}
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <meta name="description" content={description} />

    {/* topo-light.svg is the CSS background of the hero on every page — it IS
        the LCP element, but as a CSS background it's discovered late (after
        CSS parse). Preloading it cuts ~0.9s off LCP. */}
    <link rel="preload" as="image" href="/images/topo-light.svg" fetchpriority="high" />
    <link rel="canonical" href={canonicalUrl} />

    {/* Markdown twin of this page, generated post-build by
        scripts/generate-md-twins.mjs with this exact URL mapping. Utility
        pages (thanks, 404) have no twin so they emit no link. */}
    {!Astro.url.pathname.match(/\/(thanks|404)\/?$/) && (
      <link
        rel="alternate"
        type="text/markdown"
        href={Astro.url.pathname === "/" ? "/index.md" : Astro.url.pathname.replace(/\/$/, "") + ".md"}
      />
    )}

    {/* hreflang: tells Google these are EN/ES versions of the same page so
        they cluster together in search rather than competing. ES is only
        emitted when a real Spanish file exists for this route, otherwise
        we'd point Google at a noindex redirect stub and break reciprocity. */}
    <link rel="alternate" hreflang="en" href={enAbsoluteUrl} />
    {esAbsoluteUrl && (
      <link rel="alternate" hreflang="es" href={esAbsoluteUrl} />
    )}
    <link rel="alternate" hreflang="x-default" href={enAbsoluteUrl} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(resolvedOgImage, Astro.site).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:image" content={new URL(resolvedOgImage, Astro.site).toString()} />
    <meta name="twitter:image:alt" content={title} />
    <meta property="og:site_name" content="The Lay Counselor Academy" />
    <meta property="og:locale" content={lang === "es" ? "es_ES" : "en_US"} />
    <meta property="og:locale:alternate" content={lang === "es" ? "en_US" : "es_ES"} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {/* Favicons, properly cropped LCA mark at every standard size.
        Generated by scripts/generate-favicon.py from /images/lca-logo.png. */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
    <link rel="shortcut icon" href="/favicon.ico" />

    {/* Preload the hero photo on the homepage, it is the LCP candidate.
        Other pages have a text-only hero so the preload would be wasted. */}
    {Astro.url.pathname === "/" && (
      <link rel="preload" as="image" href="/images/hero-counseling-2.webp" fetchpriority="high" />
    )}
    {Astro.url.pathname === "/es/" && (
      <link rel="preload" as="image" href="/images/hero-counseling-2.webp" fetchpriority="high" />
    )}

    {/* Schema.org */}
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(webpageSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(courseSchema)} />
    {breadcrumbSchema && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )}
    {extraSchemas.map((s) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to main content</a>

    <Nav />

    <main id="main">
      <slot />
    </main>

    {/* Mobile sticky CTA, only renders below 768px, only shows after the user
        scrolls past the first viewport, hides itself when the sample-lesson
        section is on screen (so it doesn't duplicate the CTA right next to
        the form) or when the footer is visible. */}
    <div
      class="mobile-sticky-cta"
      data-mobile-sticky-cta
      hidden
      aria-hidden="true"
    >
      <a
        class="mobile-sticky-cta-primary"
        href={lang === "es" ? "/es/#sample" : "/#sample"}
      >
        {lang === "es" ? "Lee la lección de muestra" : "Read the sample article"}
      </a>
      {lang === "es" ? (
        <span class="mobile-sticky-cta-soon">Próximamente</span>
      ) : (
        <a
          class="mobile-sticky-cta-secondary"
          href="https://app.teachfloor.com/the-lay-counselor-academy/c/32305"
          rel="noopener"
          aria-label="Enroll"
        >
          Enroll
        </a>
      )}
    </div>

    <Footer />

    {/* additive motion: section reveal on scroll. inert under reduced-motion. */}
    <script is:inline>
      (function () {
        if (typeof window === "undefined") return;
        if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        if (!("IntersectionObserver" in window)) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );

        document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
      })();
    </script>

    {/* Mobile sticky CTA visibility controller. Shows the bar after the user
        scrolls a screen down, hides it when the sample form is visible or
        the footer is in view. */}
    <script is:inline>
      (function () {
        if (typeof window === "undefined") return;
        const bar = document.querySelector("[data-mobile-sticky-cta]");
        if (!bar) return;
        if (!window.matchMedia("(max-width: 767px)").matches) return;

        let scrolledPast = false;
        let sampleVisible = false;
        let footerVisible = false;

        function refresh() {
          const show = scrolledPast && !sampleVisible && !footerVisible;
          if (show) {
            bar.hidden = false;
            bar.setAttribute("aria-hidden", "false");
            bar.classList.add("is-visible");
          } else {
            bar.classList.remove("is-visible");
            bar.setAttribute("aria-hidden", "true");
            // delay hiding so the slide-out animation can play
            setTimeout(() => { if (!bar.classList.contains("is-visible")) bar.hidden = true; }, 220);
          }
        }

        // Reveal once user has scrolled at least 75% of viewport height.
        function onScroll() {
          const past = window.scrollY > window.innerHeight * 0.75;
          if (past !== scrolledPast) {
            scrolledPast = past;
            refresh();
          }
        }
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();

        if (!("IntersectionObserver" in window)) return;

        const sample = document.querySelector("#sample");
        if (sample) {
          new IntersectionObserver((entries) => {
            sampleVisible = entries.some((e) => e.isIntersecting);
            refresh();
          }, { rootMargin: "-10% 0px -10% 0px" }).observe(sample);
        }

        const footer = document.querySelector(".site-footer");
        if (footer) {
          new IntersectionObserver((entries) => {
            footerVisible = entries.some((e) => e.isIntersecting);
            refresh();
          }, { rootMargin: "0px 0px -20% 0px" }).observe(footer);
        }
      })();
    </script>

    <style is:global>
      .skip-link {
        position: absolute;
        left: 0.5rem;
        top: -3rem;
        background-color: var(--color-navy);
        color: var(--color-paper);
        padding: 0.5rem 0.875rem;
        text-decoration: none;
        font-family: var(--font-sans);
        font-size: 0.95rem;
        border-radius: 4px;
        z-index: 100;
        transition: top 180ms cubic-bezier(0.22, 1, 0.36, 1);
      }
      .skip-link:focus {
        top: 0.5rem;
      }

      /* Mobile sticky CTA, phone-only conversion bar. Slides up from the
         bottom after the user has scrolled past the first viewport. Hidden
         on tablet+ where the in-page CTAs are already at hand. */
      .mobile-sticky-cta {
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 40;
        display: none;
        gap: 0.5rem;
        padding: 0.625rem 0.875rem calc(0.625rem + env(safe-area-inset-bottom)) 0.875rem;
        background-color: var(--color-navy);
        border-top: 1px solid oklch(0.97 0.012 70 / 0.15);
        box-shadow: 0 -10px 30px -10px oklch(0 0 0 / 0.35);
        transform: translateY(100%);
        transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
      }
      .mobile-sticky-cta.is-visible {
        transform: translateY(0);
      }
      @media (max-width: 767px) {
        .mobile-sticky-cta:not([hidden]) {
          display: flex;
        }
      }
      .mobile-sticky-cta-primary {
        flex: 1 1 auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.75rem 1rem;
        background-color: var(--color-navy);
        color: var(--color-paper);
        font-family: var(--font-sans);
        font-size: 0.95rem;
        font-weight: 500;
        text-decoration: none;
        border-radius: 9999px;
        min-height: 48px;
        transition: background-color 200ms cubic-bezier(0.22, 1, 0.36, 1);
      }
      .mobile-sticky-cta-primary:hover {
        background-color: var(--color-navy-deep);
        text-decoration: none;
      }
      .mobile-sticky-cta-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.75rem 1rem;
        background-color: transparent;
        color: var(--color-on-navy);
        font-family: var(--font-sans);
        font-size: 0.9rem;
        font-weight: 500;
        text-decoration: none;
        border: 1.5px solid var(--color-coral);
        border-radius: 9999px;
        min-height: 48px;
        white-space: nowrap;
      }
      .mobile-sticky-cta-secondary:hover {
        background-color: var(--color-navy);
        color: var(--color-paper);
        text-decoration: none;
      }
      .mobile-sticky-cta-soon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        padding: 0.75rem 1rem;
